---
interface Props {
  id: string;
  name: string;
  docCount: number;
}

const { id, name, docCount } = Astro.props as Props;
---

<a class="folder-card" href={`/folder/${id}`}>
  <div class="folder-icon">📁</div>
  <div class="folder-content">
    <span class="folder-name">{name}</span>
    <span class="folder-meta">{docCount} doc{docCount !== 1 ? 's' : ''}</span>
  </div>
</a>

<style>
  .folder-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-muted);
    background: var(--bg);
    color: inherit;
    text-decoration: none;
    border-radius: 4px;
    transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
  }

  .folder-card:hover {
    transform: translateY(-1px);
    border-color: var(--border-strong);
    box-shadow: 0 4px 12px rgba(var(--shadow-rgb), 0.24);
  }

  .folder-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .folder-content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .folder-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--fg);
  }

  .folder-meta {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    text-transform: lowercase;
  }
</style>
