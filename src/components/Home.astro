---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props as Props;

const parseLocalDate = (dateString: string) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateString);
  if (!match) return null;
  const [, year, month, day] = match;
  return new Date(Number(year), Number(month) - 1, Number(day));
};
const formatMonthYear = (date: Date) => {
  const month = date.toLocaleDateString('en-US', { month: 'short' }).toLowerCase();
  return `${month} ${date.getFullYear()}`;
};
const formatShortDate = (date: Date) => {
  const month = date.toLocaleDateString('en-US', { month: 'short' }).toLowerCase();
  const day = String(date.getDate()).padStart(2, '0');
  return `${month} ${day} ${date.getFullYear()}`;
};

const latestPostDate = posts.reduce((latest, post) => {
  const date = parseLocalDate(post.data.pubDate);
  return date && date > latest ? date : latest;
}, new Date(0));
const latestPostLabel = latestPostDate.getTime() ? formatMonthYear(latestPostDate) : '—';

const catColors: Record<string, string> = {
  'gpu': 'var(--cat-gpu)',
  'ml': 'var(--cat-ml)',
  'hardware': 'var(--cat-hardware)',
  'tenstorrent': 'var(--cat-tenstorrent)',
  'bio': 'var(--cat-bio)',
  'misc': 'var(--cat-misc)',
};
const getCatColor = (cat: string) => catColors[cat] || 'var(--fg-soft)';
---

<section class="home">
  <h1 class="sr-only">boop notes: systems, machine learning, GPUs, biology, reverse engineering, and side projects</h1>

  <div class="meta">
    <span>{posts.length} posts</span>
    <span class="sep">·</span>
    <span>updated {latestPostLabel}</span>
  </div>

  <div class="section">
    <div class="section-header">
      <span class="section-title">// index</span>
      <span class="section-rule" aria-hidden="true"></span>
    </div>
    <ol class="post-index">
      {posts.map((post, idx) => {
        const num = posts.length - idx;
        const hex = `0x${num.toString(16).padStart(2, '0')}`;
        const cat = post.data.cat ?? '—';
        const date = parseLocalDate(post.data.pubDate);
        const dateLabel = date ? formatShortDate(date) : post.data.pubDate;
        const year = date?.getFullYear() ?? null;
        const prevDate = idx > 0 ? parseLocalDate(posts[idx - 1].data.pubDate) : null;
        const newYear = idx > 0 && year !== null && prevDate !== null && year !== prevDate.getFullYear();

        return (
          <>
          {newYear && (
            <li class="year-row" role="presentation">
              <span class="year-label">{year}</span>
              <span class="year-rule" aria-hidden="true"></span>
            </li>
          )}
          <li class="post-row" data-cat={cat} style={`--row-color: ${getCatColor(cat)}`}>
            <a href={`/blog/${post.id}`} class="post-link">
              <span class="post-bar" aria-hidden="true"></span>
              <span class="post-num">{hex}</span>
              <span class="post-title">{post.data.title}</span>
              <span class="post-meta">
                <span class="post-cat">{cat}</span>
                <span class="post-sep" aria-hidden="true">·</span>
                <span class="post-date">{dateLabel}</span>
              </span>
            </a>
          </li>
          </>
        );
      })}
    </ol>
  </div>
</section>

<style>
  .home {
    width: 100%;
    padding: 0.25rem 0 2rem;
    font-family: "Google Sans Code", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--fg-subtle);
    padding-bottom: 1rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .meta .sep {
    color: var(--border-strong);
  }

  /* ── sections ──────────────────────────────────────────── */

  .section {
    margin-bottom: 2.25rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .section-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--fg-subtle);
    text-transform: lowercase;
    flex-shrink: 0;
  }

  .section-rule {
    flex: 1;
    height: 1px;
    background: var(--border-soft);
  }

  /* ── post index ────────────────────────────────────────── */

  .post-index {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-row {
    border-bottom: 1px dashed var(--border-soft);
    transition: opacity 0.15s;
  }

  .post-row:first-child {
    border-top: 1px dashed var(--border-soft);
  }

  .post-row.is-dim {
    opacity: 0.3;
  }

  .year-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.4rem 0 0.85rem;
  }

  .year-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--fg-subtle);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .year-rule {
    flex: 1;
    height: 1px;
    background: var(--border-soft);
  }

  .post-link {
    display: grid;
    grid-template-columns: 4px 3.5rem 1fr auto;
    gap: 0.85rem;
    align-items: center;
    padding: 0.8rem 0.5rem 0.8rem 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }

  .post-link:hover {
    background: rgba(var(--shadow-rgb), 0.07);
  }

  .post-bar {
    background: var(--row-color);
    opacity: 0.55;
    transition: opacity 0.12s;
    align-self: stretch;
  }

  .post-link:hover .post-bar {
    opacity: 1;
  }

  .post-num {
    font-size: 0.78rem;
    color: var(--fg-faint);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.03em;
  }

  .post-link:hover .post-num {
    color: var(--row-color);
  }

  .post-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.3;
    min-width: 0;
  }

  .post-link:hover .post-title {
    color: var(--fg-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    color: var(--fg-faint);
    white-space: nowrap;
  }

  .post-cat {
    color: var(--row-color);
    text-transform: lowercase;
    font-weight: 500;
  }

  .post-sep {
    color: var(--border-strong);
  }

  .post-date {
    color: var(--fg-subtle);
    font-variant-numeric: tabular-nums;
  }

  /* ── responsive ────────────────────────────────────────── */

  @media (max-width: 640px) {
    .home {
      padding: 0.25rem 0 2rem;
    }

    .post-link {
      grid-template-columns: 4px 1fr;
      grid-template-rows: auto auto;
      gap: 0.25rem 0.7rem;
    }

    .post-bar {
      grid-row: 1 / 3;
    }

    .post-num {
      display: none;
    }

    .post-meta {
      grid-column: 2;
      grid-row: 2;
      font-size: 0.7rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
