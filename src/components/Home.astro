---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { getBookConfigs } from '../data/books';
import { resolveBookFromDocs } from '../lib/books';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props as Props;

const bookDocs = await getCollection('books', ({ data }) => data.published);
const books = getBookConfigs().map((config) => {
  const resolved = resolveBookFromDocs(config.id, bookDocs);
  return {
    id: config.id,
    name: config.title,
    chapterCount: resolved.chapters.length,
  };
});

const parseLocalDate = (dateString: string) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateString);
  if (!match) return null;
  const [, year, month, day] = match;
  return new Date(Number(year), Number(month) - 1, Number(day));
};
const formatLongDate = (date: Date) => date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).toLowerCase();
const formatShortDate = (date: Date) => {
  const month = date.toLocaleDateString('en-US', { month: 'short' }).toLowerCase();
  const day = String(date.getDate()).padStart(2, '0');
  return `${month} ${day} ${date.getFullYear()}`;
};

const latestPostDate = posts.reduce((latest, post) => {
  const date = parseLocalDate(post.data.pubDate);
  return date && date > latest ? date : latest;
}, new Date(0));
const latestPostLabel = latestPostDate.getTime() ? formatLongDate(latestPostDate) : '—';

const catColors: Record<string, string> = {
  'gpu': 'var(--cat-gpu)',
  'ml': 'var(--cat-ml)',
  'hardware': 'var(--cat-hardware)',
  'bio': 'var(--cat-bio)',
  'misc': 'var(--cat-misc)',
};
const getCatColor = (cat: string) => catColors[cat] || 'var(--fg-soft)';

const categoryCount = new Set(posts.map(p => p.data.cat).filter(Boolean)).size;
---

<section class="home">
  <h1 class="sr-only">anuraag notes: systems, machine learning, GPUs, biology, reverse engineering, and side projects</h1>

  <div class="meta">
    <span>{posts.length} posts</span>
    <span class="sep">/</span>
    <span>{categoryCount} cats</span>
    <span class="sep">/</span>
    <span>{books.length} {books.length === 1 ? 'book' : 'books'}</span>
    <span class="sep">/</span>
    <span>updated {latestPostLabel}</span>
  </div>

  {books.length > 0 && (
    <div class="section">
      <div class="section-header">
        <span class="section-title">// books</span>
        <span class="section-rule" aria-hidden="true"></span>
      </div>
      <ul class="book-list">
        {books.map((book) => (
          <li class="book-row">
            <a class="book-link" href={`/book/${book.id}`}>
              <span class="book-mark" aria-hidden="true">▌</span>
              <span class="book-name">{book.name}</span>
              <span class="book-chapters">{book.chapterCount} chapter{book.chapterCount !== 1 ? 's' : ''}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <div class="section">
    <div class="section-header">
      <span class="section-title">// index</span>
      <span class="section-rule" aria-hidden="true"></span>
    </div>
    <ol class="post-index">
      {posts.map((post, idx) => {
        const num = posts.length - idx;
        const hex = `0x${num.toString(16).padStart(2, '0')}`;
        const cat = post.data.cat ?? '—';
        const date = parseLocalDate(post.data.pubDate);
        const dateLabel = date ? formatShortDate(date) : post.data.pubDate;

        return (
          <li class="post-row" style={`--row-color: ${getCatColor(cat)}`}>
            <a href={`/blog/${post.id}`} class="post-link">
              <span class="post-bar" aria-hidden="true"></span>
              <span class="post-num">{hex}</span>
              <span class="post-title">{post.data.title}</span>
              <span class="post-meta">
                <span class="post-cat">{cat}</span>
                <span class="post-sep" aria-hidden="true">·</span>
                <span class="post-date">{dateLabel}</span>
              </span>
            </a>
          </li>
        );
      })}
    </ol>
  </div>

  <footer class="signoff" aria-hidden="true">
    <pre class="ascii-cat" set:html={`  /\\_/\\
 ( o.o )
  &gt; ^ &lt;`} />
  </footer>
</section>

<style>
  .home {
    max-width: 820px;
    margin: 0 auto;
    padding: 1rem 1rem 4rem;
    font-family: "Google Sans Code", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--fg-subtle);
    padding-bottom: 1rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .meta .sep {
    color: var(--border-strong);
  }

  /* ── sections ──────────────────────────────────────────── */

  .section {
    margin-bottom: 2.25rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .section-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--fg-subtle);
    text-transform: lowercase;
    flex-shrink: 0;
  }

  .section-rule {
    flex: 1;
    height: 1px;
    background: var(--border-soft);
  }

  /* ── books ─────────────────────────────────────────────── */

  .book-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .book-row + .book-row {
    margin-top: 0.4rem;
  }

  .book-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 0.85rem;
    padding: 0.7rem 0.95rem 0.7rem 0.7rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border-muted);
    border-radius: 4px;
    background: var(--bg);
    transition: border-color 0.12s, transform 0.12s, box-shadow 0.12s;
  }

  .book-link:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(var(--shadow-rgb), 0.18);
  }

  .book-mark {
    color: var(--fg-subtle);
    font-size: 1.05rem;
    line-height: 1;
    align-self: center;
  }

  .book-link:hover .book-mark {
    color: var(--fg);
  }

  .book-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--fg-strong);
  }

  .book-chapters {
    font-size: 0.72rem;
    color: var(--fg-subtle);
    white-space: nowrap;
  }

  /* ── post index ────────────────────────────────────────── */

  .post-index {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-row {
    border-bottom: 1px dashed var(--border-soft);
  }

  .post-row:first-child {
    border-top: 1px dashed var(--border-soft);
  }

  .post-link {
    display: grid;
    grid-template-columns: 4px 3.5rem 1fr auto;
    gap: 0.85rem;
    align-items: center;
    padding: 0.8rem 0.5rem 0.8rem 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }

  .post-link:hover {
    background: rgba(var(--shadow-rgb), 0.07);
  }

  .post-bar {
    background: var(--row-color);
    opacity: 0.55;
    transition: opacity 0.12s;
    align-self: stretch;
  }

  .post-link:hover .post-bar {
    opacity: 1;
  }

  .post-num {
    font-size: 0.78rem;
    color: var(--fg-faint);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.03em;
  }

  .post-link:hover .post-num {
    color: var(--row-color);
  }

  .post-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.3;
    min-width: 0;
  }

  .post-link:hover .post-title {
    color: var(--fg-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    color: var(--fg-faint);
    white-space: nowrap;
  }

  .post-cat {
    color: var(--row-color);
    text-transform: lowercase;
    font-weight: 500;
  }

  .post-sep {
    color: var(--border-strong);
  }

  .post-date {
    color: var(--fg-subtle);
    font-variant-numeric: tabular-nums;
  }

  /* ── signoff ───────────────────────────────────────────── */

  .signoff {
    text-align: center;
    padding: 2.5rem 0 0;
    opacity: 0.4;
    transition: opacity 0.3s;
  }

  .signoff:hover {
    opacity: 0.8;
  }

  .ascii-cat {
    font-size: 0.95rem;
    line-height: 1.2;
    margin: 0;
    color: var(--fg);
  }

  /* ── responsive ────────────────────────────────────────── */

  @media (max-width: 640px) {
    .home {
      padding: 1rem 0.85rem 3rem;
    }

    .post-link {
      grid-template-columns: 4px 1fr;
      grid-template-rows: auto auto;
      gap: 0.25rem 0.7rem;
    }

    .post-bar {
      grid-row: 1 / 3;
    }

    .post-num {
      display: none;
    }

    .post-meta {
      grid-column: 2;
      grid-row: 2;
      font-size: 0.7rem;
    }

    .book-link {
      grid-template-columns: auto 1fr;
      gap: 0.7rem;
    }

    .book-chapters {
      grid-column: 2;
      grid-row: 2;
      padding-top: 0.15rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
