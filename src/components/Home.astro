---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import FolderCard from './FolderCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props as Props;
const regularPosts = posts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

// Get folders data
const folderDocs = await getCollection('folders', ({ data }) => data.published);
const folderMap = new Map<string, CollectionEntry<'folders'>[]>();
folderDocs.forEach(doc => {
  const [folderId] = doc.id.split('/');
  if (!folderMap.has(folderId)) {
    folderMap.set(folderId, []);
  }
  folderMap.get(folderId)!.push(doc);
});
const folders = Array.from(folderMap.entries()).map(([id, docs]) => ({
  id,
  name: id.replace(/-/g, ' ').split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
  docCount: docs.length,
}));

const workingOn = [
  'tinygrad bounties',
  'learning rdna',
  'educational resources',
  'compilers / ml',
];

const formatLongDate = (date: Date) => date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).toLowerCase();
const parseLocalDate = (dateString: string) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateString);
  if (!match) return null;
  const [, year, month, day] = match;
  return new Date(Number(year), Number(month) - 1, Number(day));
};
const formatPostDate = (dateString: string) => {
  const date = parseLocalDate(dateString);
  return date ? formatLongDate(date) : dateString;
};

const latestPostDate = posts.reduce((latest, post) => {
  const date = parseLocalDate(post.data.pubDate);
  return date && date > latest ? date : latest;
}, new Date(0));
const latestPostLabel = latestPostDate.getTime() ? formatLongDate(latestPostDate) : '—';
const githubGraphLightSrc = '/images/github-heat-light.svg';
const githubGraphDarkSrc = '/images/github-heat-dark.svg';

// Category colors (theme-aware CSS variables)
const catColors: Record<string, string> = {
  'gpu': 'var(--cat-gpu)',
  'ml': 'var(--cat-ml)',
  'hardware': 'var(--cat-hardware)',
  'bio': 'var(--cat-bio)',
  'misc': 'var(--cat-misc)',
};
const getCatColor = (cat: string) => catColors[cat] || 'var(--fg-soft)';

// Get unique mapped categories
const categories = [...new Set(regularPosts.map(p => p.data.cat ?? '—').filter(c => c !== '—'))];
---

<section class="brutalist-home">
  <h1 class="sr-only">anuraag notes: systems, machine learning, GPUs, biology, reverse engineering, and side projects</h1>
  <div class="masthead">
    <div class="github-graph">
      <img
        class="github-graph-img"
        data-github-graph
        data-light-src={githubGraphLightSrc}
        data-dark-src={githubGraphDarkSrc}
        src={githubGraphLightSrc}
        alt="GitHub contribution graph"
        loading="lazy"
      />
    </div>
    <div class="meta-block">
      <span class="meta-item">{posts.length} posts</span>
      <span class="meta-sep">/</span>
      <span class="meta-item">{categories.length} categories</span>
      <span class="meta-sep">/</span>
      <span class="meta-item">{folders.length} folders</span>
      <span class="meta-sep">/</span>
      <span class="meta-item">updated {latestPostLabel}</span>
    </div>
  </div>

  <div class="working-strip">
    <span class="working-label">now:</span>
    {workingOn.map((item, i) => (
      <span class="working-item">{item}{i < workingOn.length - 1 ? ',' : ''}</span>
    ))}
  </div>

  {folders.length > 0 && (
    <div class="folders-section">
      <div class="section-header">folders</div>
      <div class="folders-grid">
        {folders.map((folder) => (
          <FolderCard id={folder.id} name={folder.name} docCount={folder.docCount} />
        ))}
      </div>
    </div>
  )}

  <div class="index-section">
    <div class="section-header">index</div>
    <ol class="post-index">
      {regularPosts.map((post, idx) => {
        const indexNum = String(regularPosts.length - idx).padStart(2, '0');
        const catLabel = post.data.cat ?? '—';

        return (
          <li class="index-item">
            <a href={`/blog/${post.id}`} class="index-link">
              <span class="index-num">{indexNum}</span>
              <span class="index-title">{post.data.title}</span>
              <span class="index-meta">
                <span class="index-cat" style={`color: ${getCatColor(catLabel)}`}>{catLabel}</span>
                <span class="index-date">{formatPostDate(post.data.pubDate)}</span>
              </span>
            </a>
          </li>
        );
      })}
    </ol>
  </div>

  <div class="footer-art" aria-hidden="true">
    <pre class="ascii-cat" set:html={`  /\\_/\\
 ( o.o )
  &gt; ^ &lt;`} />
  </div>
</section>

<style>
  .brutalist-home {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 1rem 4rem;
    font-family: "Google Sans Code", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .masthead {
    padding: 0 0 1.25rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .github-graph {
    margin-bottom: 0.5rem;
    overflow-x: auto;
    background: var(--surface-soft);
    border: 1px solid var(--border-soft);
    border-radius: 6px;
    padding: 0.45rem;
  }

  .github-graph-img {
    width: 100%;
    height: auto;
    display: block;
    opacity: 0.95;
    transition: opacity 0.24s ease;
  }

  .meta-block {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--fg-subtle);
  }

  .meta-sep {
    color: var(--border-strong);
  }

  .working-strip {
    color: var(--fg-faint);
    padding: 0;
    margin-bottom: 1.5rem;
    font-size: 0.82rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
  }

  .working-label {
    font-weight: 700;
    color: var(--fg-soft);
  }

  .working-item {
    color: var(--fg-subtle);
  }

  .folders-section {
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .section-header {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--fg-subtle);
    margin-bottom: 0.75rem;
    text-transform: lowercase;
  }

  .folders-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .folders-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }


  .index-section {
    margin-bottom: 3rem;
  }

  .post-index {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: none;
  }

  .index-item {
    border-bottom: 1px solid var(--border-soft);
  }

  .index-item:first-child {
    border-top: 1px solid var(--border-soft);
  }

  .index-link {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 1rem;
    align-items: baseline;
    padding: 0.75rem 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
  }

  .index-link:hover {
    background: rgba(var(--shadow-rgb), 0.12);
  }

  .index-num {
    font-size: 0.8rem;
    color: var(--fg-subtle);
    font-weight: 600;
  }

  .index-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.3;
  }

  .index-link:hover .index-title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .index-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.78rem;
    color: var(--fg-faint);
    white-space: nowrap;
  }

  .index-cat {
    text-transform: lowercase;
    min-width: 6rem;
    text-align: right;
  }

  .index-date {
    color: var(--fg-subtle);
    font-variant-numeric: tabular-nums;
  }

  .footer-art {
    text-align: center;
    padding: 2rem;
    opacity: 0.3;
    transition: opacity 0.3s;
  }

  .footer-art:hover {
    opacity: 0.8;
  }

  .ascii-cat {
    font-size: 1rem;
    line-height: 1.2;
    margin: 0;
    color: var(--fg);
  }

  @media (max-width: 600px) {
    .github-graph {
      display: none;
    }

    .masthead {
      padding: 0 0 1rem;
    }

    .index-link {
      grid-template-columns: 2rem 1fr;
      grid-template-rows: auto auto;
      gap: 0.25rem 0.75rem;
    }

    .index-num {
      grid-row: 1 / 3;
      align-self: start;
      padding-top: 0.1rem;
    }

    .index-meta {
      grid-column: 2;
      justify-content: flex-start;
      gap: 1rem;
    }

    .index-cat {
      min-width: auto;
      text-align: left;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>

<script>
  (() => {
    const graph = document.querySelector('[data-github-graph]');
    if (!(graph instanceof HTMLImageElement)) return;
    const root = document.documentElement;
    const lightSrc = graph.dataset.lightSrc;
    const darkSrc = graph.dataset.darkSrc;
    if (!lightSrc || !darkSrc) return;

    const syncGraphTheme = () => {
      const nextSrc = root.dataset.theme === 'dark' ? darkSrc : lightSrc;
      if (graph.src !== nextSrc) graph.src = nextSrc;
    };

    syncGraphTheme();
    new MutationObserver(syncGraphTheme).observe(root, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  })();
</script>
