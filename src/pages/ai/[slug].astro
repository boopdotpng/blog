---
import fs from 'node:fs';
import path from 'node:path';

type AiPageProps = {
  content: string;
  kind: 'html' | 'svg';
};

export async function getStaticPaths() {
  const aiDir = path.resolve('./src/content/ai');
  const paths: Array<{ params: { slug: string }; props: AiPageProps }> = [];
  if (fs.existsSync(aiDir)) {
    for (const file of fs.readdirSync(aiDir)) {
      if (!file.endsWith('.html') && !file.endsWith('.svg')) continue;
      const kind = file.endsWith('.svg') ? 'svg' : 'html';
      const slug = file.replace(/\.(html|svg)$/, '');
      const content = fs.readFileSync(path.join(aiDir, file), 'utf-8');
      paths.push({ params: { slug }, props: { content, kind } });
    }
  }

  return paths;
}

const props = Astro.props as AiPageProps;

const BACK_PILL = `<a href="/ai" id="__ai-corner-back" aria-label="Back to ai corner">← ai corner</a><style id="__ai-corner-back-style">
#__ai-corner-back{position:fixed;top:14px;left:14px;z-index:2147483647;display:inline-flex;align-items:center;gap:6px;padding:7px 12px;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;font-size:12px;line-height:1;letter-spacing:.04em;color:#1a1a1a;background:rgba(255,255,255,.88);border:1px solid rgba(0,0,0,.14);border-radius:999px;text-decoration:none;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);box-shadow:0 2px 10px rgba(0,0,0,.16);transition:transform .12s ease,background .12s ease,box-shadow .12s ease}
#__ai-corner-back:hover{background:rgba(255,255,255,.98);transform:translateY(-1px);box-shadow:0 4px 14px rgba(0,0,0,.2)}
@media (prefers-color-scheme: dark){#__ai-corner-back{color:#e6edf3;background:rgba(20,22,28,.72);border-color:rgba(255,255,255,.14);box-shadow:0 2px 10px rgba(0,0,0,.45)}#__ai-corner-back:hover{background:rgba(28,30,36,.92)}}
@media print{#__ai-corner-back,#__ai-corner-back-style{display:none!important}}
</style>`;

const extractSvgData = (svg: string, name: string): string | undefined => {
  const tag = svg.match(/<svg\b[^>]*>/i)?.[0];
  if (!tag) return undefined;
  const content = tag.match(new RegExp(`\\sdata-${name}=["']([^"']+)["']`, 'i'))?.[1];
  return content?.trim() || undefined;
};

const escapeHtml = (value: string) => value
  .replace(/&/g, '&amp;')
  .replace(/</g, '&lt;')
  .replace(/>/g, '&gt;')
  .replace(/"/g, '&quot;');

const renderSvgPage = (rawSvg: string) => {
  const title = extractSvgData(rawSvg, 'ai-title') || 'svg';

  // Inline the SVG as real DOM (vector) rather than a base64 <img>, and drive
  // pan/zoom by mutating the SVG's viewBox instead of a CSS transform. A CSS
  // transform scales a cached raster (blurry text when zoomed); changing the
  // viewBox re-renders the vector crisply at every zoom level — fast and sharp,
  // including on iPad. Strip the XML prolog / DOCTYPE since the markup now lives
  // inside HTML; the SVG fills the viewport via CSS and the viewBox is the camera.
  const svgStart = rawSvg.search(/<svg\b/i);
  const inlineSvg = svgStart >= 0 ? rawSvg.slice(svgStart) : rawSvg;

  return `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<title>${escapeHtml(title)}</title>
<style>
  html, body { width: 100%; height: 100%; margin: 0; overflow: hidden; background: #0f1117; overscroll-behavior: none; }
  #__ai-svg-viewer { position: fixed; inset: 0; overflow: hidden; touch-action: none; user-select: none; -webkit-user-select: none; cursor: grab; }
  #__ai-svg-viewer.is-grabbing { cursor: grabbing; }
  #__ai-svg-viewer > svg { position: absolute; inset: 0; display: block; width: 100%; height: 100%; pointer-events: none; }
</style>
</head>
<body>
<div id="__ai-svg-viewer" aria-label="${escapeHtml(title)}">${inlineSvg}</div>
<script>
(() => {
  const viewer = document.getElementById('__ai-svg-viewer');
  const svg = viewer && viewer.querySelector('svg');
  if (!viewer || !svg) return;

  const base = (svg.getAttribute('viewBox') || '').split(/[\\s,]+/).map(Number);
  if (base.length !== 4 || base.some(Number.isNaN)) return;
  const GRAPH = { x: base[0], y: base[1], w: base[2], h: base[3] };
  svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');

  const MAX_IN = 32;     // furthest zoom-in (viewBox = fit / MAX_IN)
  const MAX_OUT = 2.5;   // furthest zoom-out (viewBox = fit * MAX_OUT)
  const PINCH_SENS = 4.5;   // touch / Safari-gesture pinch sensitivity (>1 = more)
  const WHEEL_ZOOM = 0.0075; // ctrl+wheel pinch sensitivity (Chrome/FF trackpads; higher = more)

  // Current camera (viewBox). Kept at the window's aspect ratio so screen
  // pixels map linearly to user units with no letterbox maths.
  const vb = { x: 0, y: 0, w: GRAPH.w, h: GRAPH.h };
  let fitW = GRAPH.w;

  const vw = () => viewer.clientWidth || window.innerWidth;
  const vh = () => viewer.clientHeight || window.innerHeight;
  const apply = () => svg.setAttribute('viewBox', vb.x + ' ' + vb.y + ' ' + vb.w + ' ' + vb.h);

  // Smallest window-aspect box that fully contains the graph.
  const fitBox = () => {
    const winA = vw() / vh();
    return winA > GRAPH.w / GRAPH.h
      ? { w: GRAPH.h * winA, h: GRAPH.h }
      : { w: GRAPH.w, h: GRAPH.w / winA };
  };

  const reset = () => {
    const f = fitBox();
    fitW = f.w;
    vb.w = f.w; vb.h = f.h;
    vb.x = GRAPH.x + (GRAPH.w - vb.w) / 2;
    vb.y = GRAPH.y + (GRAPH.h - vb.h) / 2;
    apply();
  };

  const clampZoom = () => {
    const a = vb.w / vb.h;
    const min = fitW / MAX_IN;
    const max = fitW * MAX_OUT;
    if (vb.w < min) { vb.w = min; vb.h = min / a; }
    else if (vb.w > max) { vb.w = max; vb.h = max / a; }
  };

  // Zoom by factor k (k < 1 zooms in) keeping the client point fixed.
  const zoomAt = (k, cx, cy) => {
    const rect = viewer.getBoundingClientRect();
    const fx = (cx - rect.left) / rect.width;
    const fy = (cy - rect.top) / rect.height;
    const sx = vb.x + fx * vb.w;
    const sy = vb.y + fy * vb.h;
    vb.w *= k; vb.h *= k;
    clampZoom();
    vb.x = sx - fx * vb.w;
    vb.y = sy - fy * vb.h;
    apply();
  };

  // Pan so content follows a client-pixel delta.
  const panPixels = (dx, dy) => {
    vb.x -= dx * vb.w / vw();
    vb.y -= dy * vb.h / vh();
    apply();
  };

  reset();
  window.addEventListener('resize', () => {
    const cx = vb.x + vb.w / 2, cy = vb.y + vb.h / 2;
    vb.h = vb.w / (vw() / vh());
    fitW = fitBox().w;
    clampZoom();
    vb.x = cx - vb.w / 2;
    vb.y = cy - vb.h / 2;
    apply();
  });

  // Trackpad / mouse: ctrl+wheel (pinch on Chrome/FF trackpads) zooms, a plain
  // two-finger swipe pans.
  viewer.addEventListener('wheel', (event) => {
    event.preventDefault();
    if (event.ctrlKey) {
      zoomAt(Math.exp(event.deltaY * WHEEL_ZOOM), event.clientX, event.clientY);
      return;
    }
    const m = event.deltaMode === 1 ? 16 : event.deltaMode === 2 ? Math.max(vw(), vh()) : 1;
    panPixels(-event.deltaX * m, -event.deltaY * m);
  }, { passive: false });

  // Pointers: one finger / drag pans, two fingers pinch-zoom and pan together.
  const pts = new Map();
  let pinch = null;
  viewer.addEventListener('pointerdown', (event) => {
    viewer.setPointerCapture(event.pointerId);
    pts.set(event.pointerId, { x: event.clientX, y: event.clientY });
    viewer.classList.add('is-grabbing');
    if (pts.size === 2) pinch = null;
  });
  viewer.addEventListener('pointermove', (event) => {
    if (!pts.has(event.pointerId)) return;
    const prev = pts.get(event.pointerId);
    pts.set(event.pointerId, { x: event.clientX, y: event.clientY });
    if (pts.size === 1) {
      panPixels(event.clientX - prev.x, event.clientY - prev.y);
    } else if (pts.size === 2) {
      const [a, b] = [...pts.values()];
      const dist = Math.hypot(a.x - b.x, a.y - b.y);
      const midX = (a.x + b.x) / 2, midY = (a.y + b.y) / 2;
      if (pinch) {
        if (pinch.dist > 0 && dist > 0) zoomAt(Math.pow(pinch.dist / dist, PINCH_SENS), midX, midY);
        panPixels(midX - pinch.midX, midY - pinch.midY);
      }
      pinch = { dist, midX, midY };
    }
  });
  const endPointer = (event) => {
    pts.delete(event.pointerId);
    if (pts.size < 2) pinch = null;
    if (!pts.size) viewer.classList.remove('is-grabbing');
  };
  viewer.addEventListener('pointerup', endPointer);
  viewer.addEventListener('pointercancel', endPointer);

  // Desktop Safari trackpad pinch fires gesture events (no touch pointers down).
  // Skip them while fingers are on the screen — the pointer handler owns that.
  let lastScale = 1;
  viewer.addEventListener('gesturestart', (event) => { event.preventDefault(); lastScale = event.scale || 1; }, { passive: false });
  viewer.addEventListener('gesturechange', (event) => {
    event.preventDefault();
    if (pts.size) return;
    const s = event.scale || 1;
    zoomAt(Math.pow(lastScale / s, PINCH_SENS), event.clientX || vw() / 2, event.clientY || vh() / 2);
    lastScale = s;
  }, { passive: false });
  viewer.addEventListener('gestureend', (event) => { event.preventDefault(); lastScale = 1; }, { passive: false });

  // Double-click / double-tap resets to the fitted view.
  viewer.addEventListener('dblclick', reset);
  let lastTap = 0;
  viewer.addEventListener('pointerup', (event) => {
    if (event.pointerType !== 'touch') return;
    if (event.timeStamp - lastTap < 300) reset();
    lastTap = event.timeStamp;
  });
})();
</script>
</body>
</html>`;
};

let passthroughHtml = '';
// Inject the pill right after the opening <body> tag; fall back to prepend.
const sourceHtml = props.kind === 'svg' ? renderSvgPage(props.content) : props.content;
const bodyMatch = sourceHtml.match(/<body\b[^>]*>/i);
if (bodyMatch) {
  const idx = bodyMatch.index! + bodyMatch[0].length;
  passthroughHtml = sourceHtml.slice(0, idx) + BACK_PILL + sourceHtml.slice(idx);
} else {
  passthroughHtml = BACK_PILL + sourceHtml;
}
---
<Fragment set:html={passthroughHtml} />
