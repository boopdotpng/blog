---
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const aiDir = path.resolve('./src/content/ai');
  const htmlPaths: Array<{ params: { slug: string }; props: { html: string } }> = [];
  if (fs.existsSync(aiDir)) {
    for (const file of fs.readdirSync(aiDir)) {
      if (!file.endsWith('.html')) continue;
      const slug = file.replace(/\.html$/, '');
      const html = fs.readFileSync(path.join(aiDir, file), 'utf-8');
      htmlPaths.push({ params: { slug }, props: { html } });
    }
  }

  return htmlPaths;
}

const props = Astro.props as { html: string };

const BACK_PILL = `<a href="/ai" id="__ai-corner-back" aria-label="Back to ai corner">← ai corner</a><style id="__ai-corner-back-style">
#__ai-corner-back{position:fixed;top:14px;left:14px;z-index:2147483647;display:inline-flex;align-items:center;gap:6px;padding:7px 12px;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;font-size:12px;line-height:1;letter-spacing:.04em;color:#1a1a1a;background:rgba(255,255,255,.88);border:1px solid rgba(0,0,0,.14);border-radius:999px;text-decoration:none;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);box-shadow:0 2px 10px rgba(0,0,0,.16);transition:transform .12s ease,background .12s ease,box-shadow .12s ease}
#__ai-corner-back:hover{background:rgba(255,255,255,.98);transform:translateY(-1px);box-shadow:0 4px 14px rgba(0,0,0,.2)}
@media (prefers-color-scheme: dark){#__ai-corner-back{color:#e6edf3;background:rgba(20,22,28,.72);border-color:rgba(255,255,255,.14);box-shadow:0 2px 10px rgba(0,0,0,.45)}#__ai-corner-back:hover{background:rgba(28,30,36,.92)}}
@media print{#__ai-corner-back,#__ai-corner-back-style{display:none!important}}
</style>`;

let passthroughHtml = '';
// Inject the pill right after the opening <body> tag; fall back to prepend.
const bodyMatch = props.html.match(/<body\b[^>]*>/i);
if (bodyMatch) {
  const idx = bodyMatch.index! + bodyMatch[0].length;
  passthroughHtml = props.html.slice(0, idx) + BACK_PILL + props.html.slice(idx);
} else {
  passthroughHtml = BACK_PILL + props.html;
}
---
<Fragment set:html={passthroughHtml} />
