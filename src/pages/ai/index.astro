---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';

interface AiEntry {
  slug: string;
  title: string;
  description?: string;
  date: string; // YYYY-MM-DD when known, else ''
  dateLabel: string;
  kind: string; // 'writing' | 'html' | 'svg' | custom
  model?: string;
  href: string;
}

const decodeHtmlEntities = (value: string) => value
  .replace(/&amp;/g, '&')
  .replace(/&lt;/g, '<')
  .replace(/&gt;/g, '>')
  .replace(/&quot;/g, '"')
  .replace(/&#39;/g, "'");

/** Extract <meta name="ai-model" content="..."> from a raw html string. */
const extractHtmlMeta = (html: string, name: string): string | undefined => {
  const re = new RegExp(`<meta\\s+[^>]*name=["']${name}["'][^>]*>`, 'i');
  const tag = html.match(re)?.[0];
  if (!tag) return undefined;
  const content = tag.match(/content=["']([^"']+)["']/i)?.[1];
  return content?.trim() || undefined;
};

const extractHtmlTitle = (html: string): string | undefined => {
  const title = html.match(/<title[^>]*>(.*?)<\/title>/is)?.[1];
  return title ? decodeHtmlEntities(title).replace(/\s+/g, ' ').trim() || undefined : undefined;
};

/** Extract data-* metadata from a raw svg string. */
const extractSvgData = (svg: string, name: string): string | undefined => {
  const tag = svg.match(/<svg\b[^>]*>/i)?.[0];
  if (!tag) return undefined;
  const content = tag.match(new RegExp(`\\sdata-${name}=["']([^"']+)["']`, 'i'))?.[1];
  return content?.trim() || undefined;
};

const parseLocalDate = (dateString: string) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateString);
  if (!match) return null;
  const [, year, month, day] = match;
  return new Date(Number(year), Number(month) - 1, Number(day));
};
const formatShort = (date: Date) => {
  const month = date.toLocaleDateString('en-US', { month: 'short' }).toLowerCase();
  const day = String(date.getDate()).padStart(2, '0');
  return `${month} ${day} ${date.getFullYear()}`;
};

// Scan src/content/ai for raw .html and .svg files (served via /ai/[slug]).
const aiDir = path.resolve('./src/content/ai');
const aiEntries: AiEntry[] = [];
if (fs.existsSync(aiDir)) {
  for (const file of fs.readdirSync(aiDir)) {
    if (!file.endsWith('.html') && !file.endsWith('.svg')) continue;
    const kind = file.endsWith('.svg') ? 'svg' : 'html';
    const slug = file.replace(/\.(html|svg)$/, '');
    const filePath = path.join(aiDir, file);
    const stat = fs.statSync(filePath);
    const mtime = stat.mtime;
    const raw = fs.readFileSync(filePath, 'utf-8');
    const metadataDate = kind === 'html' ? extractHtmlMeta(raw, 'ai-date') : extractSvgData(raw, 'ai-date');
    const date = metadataDate || mtime.toISOString().slice(0, 10);
    const parsedDate = parseLocalDate(date);
    const title = kind === 'html'
      ? extractHtmlTitle(raw) || slug.replace(/[-_]/g, ' ')
      : extractSvgData(raw, 'ai-title') || slug.replace(/[-_]/g, ' ');
    aiEntries.push({
      slug,
      title: title.toLowerCase(),
      date,
      dateLabel: formatShort(parsedDate || mtime),
      kind,
      model: kind === 'html' ? extractHtmlMeta(raw, 'ai-model') : extractSvgData(raw, 'ai-model'),
      href: `/ai/${slug}`,
    });
  }
}

const allEntries = aiEntries.sort((a, b) =>
  b.date.localeCompare(a.date),
);
---
<Layout
  title="ai corner"
  description="A small corner for AI-generated writings, html, and random svgs."
  robots="noindex,follow"
>
  <section class="ai-corner">
    <header class="corner-head">
      <div class="kicker">// ai corner</div>
      <h1 class="corner-title">ai corner</h1>
      <p class="corner-blurb">
        a place for ai-generated writings, html, and random svgs.
      </p>
      <p class="corner-note">
        my own posts live on the <a href="/">main index</a>.
      </p>
    </header>

    {allEntries.length === 0 ? (
      <p class="empty">nothing here yet — drop <code>.html</code> or <code>.svg</code> files into <code>src/content/ai/</code>.</p>
    ) : (
      <ol class="entry-list">
        {allEntries.map((entry, idx) => {
          const num = allEntries.length - idx;
          const hex = `0x${num.toString(16).padStart(2, '0')}`;
          return (
            <li class="entry-row">
              <a class="entry-link" href={entry.href}>
                <span class="entry-num">{hex}</span>
                <span class="entry-body">
                  <span class="entry-title">{entry.title}</span>
                  {entry.description && (
                    <span class="entry-desc">{entry.description}</span>
                  )}
                </span>
                <span class="entry-meta">
                  <span class="entry-kind">{entry.kind}</span>
                  {entry.model && (
                    <>
                      <span class="entry-sep" aria-hidden="true">·</span>
                      <span class="entry-model">{entry.model.toLowerCase()}</span>
                    </>
                  )}
                  <span class="entry-sep" aria-hidden="true">·</span>
                  <span class="entry-date">{entry.dateLabel}</span>
                </span>
              </a>
            </li>
          );
        })}
      </ol>
    )}
  </section>
</Layout>

<style>
  .ai-corner {
    max-width: 820px;
    margin: 0 auto;
    padding: 1rem 1rem 4rem;
    font-family: var(--font-mono);
  }

  .corner-head {
    padding-bottom: 1.5rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--fg-subtle);
    text-transform: lowercase;
    margin-bottom: 0.6rem;
  }

  .corner-title {
    margin: 0 0 0.6rem;
    font-size: 2rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--fg-strong);
  }

  .corner-blurb {
    margin: 0 0 0.4rem;
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--fg-muted);
    max-width: 56rem;
  }

  .corner-blurb code,
  .corner-note code,
  .empty code {
    font-size: 0.85em;
    background: var(--surface-elev);
    padding: 0.06rem 0.32rem;
    border-radius: 3px;
    color: var(--fg);
  }

  .corner-note {
    margin: 0;
    font-size: 0.82rem;
    color: var(--fg-subtle);
  }

  .corner-note a {
    color: var(--fg-muted);
    text-decoration: none;
    border-bottom: 1px dashed var(--border-strong);
  }

  .corner-note a:hover {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }

  .empty {
    color: var(--fg-muted);
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  .entry-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .entry-row {
    border-bottom: 1px dashed var(--border-soft);
  }

  .entry-row:first-child {
    border-top: 1px dashed var(--border-soft);
  }

  .entry-link {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    gap: 0.85rem;
    align-items: center;
    padding: 0.85rem 0.5rem 0.85rem 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }

  .entry-link:hover {
    background: rgba(var(--shadow-rgb), 0.07);
  }

  .entry-num {
    font-size: 0.78rem;
    color: var(--fg-faint);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.03em;
  }

  .entry-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .entry-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.3;
  }

  .entry-link:hover .entry-title {
    color: var(--fg-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .entry-desc {
    margin-top: 0.2rem;
    font-size: 0.8rem;
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .entry-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    color: var(--fg-faint);
    white-space: nowrap;
  }

  .entry-kind {
    color: var(--fg-subtle);
    text-transform: lowercase;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .entry-model {
    color: var(--fg-faint);
    font-style: italic;
    letter-spacing: 0.02em;
  }

  .entry-sep {
    color: var(--border-strong);
  }

  .entry-date {
    color: var(--fg-subtle);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 640px) {
    .entry-link {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .entry-num {
      display: none;
    }

    .entry-meta {
      font-size: 0.7rem;
    }
  }
</style>
