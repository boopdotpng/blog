---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const folderDocs = await getCollection('folders', ({ data }) => data.published);

  // Extract unique folder names from doc IDs (format: "folder/doc")
  const folderIds = new Set<string>();
  folderDocs.forEach(doc => {
    const [folderId] = doc.id.split('/');
    folderIds.add(folderId);
  });

  return Array.from(folderIds).map(folderId => ({
    params: { id: folderId },
  }));
}

const { id: folderId } = Astro.params;
const folderDocs = await getCollection('folders', ({ data }) => data.published);
const docsInFolder = folderDocs
  .filter(doc => doc.id.startsWith(`${folderId}/`))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const formatPostDate = (dateString: string) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateString);
  if (!match) return dateString;
  const [, year, month, day] = match;
  const date = new Date(Number(year), Number(month) - 1, Number(day));
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).toLowerCase();
};

const folderName = folderId ? folderId.replace(/-/g, ' ') : '';
const description = `${docsInFolder.length} documents about ${folderName}`;
---

<Layout
  title={folderName}
  description={description}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "home", "item": "https://anuraagw.me" },
      { "@type": "ListItem", "position": 2, "name": folderName },
    ],
  }}
>
  <style>
    .folder-header {
      padding: 2rem 0 1.5rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-soft);
    }

    .folder-title {
      font-size: 2rem;
      font-weight: 700;
      margin: 0 0 0.5rem;
      font-family: var(--font-mono);
      color: var(--fg-strong);
    }

    .folder-description {
      color: var(--fg-muted);
      font-size: 0.95rem;
      margin: 0;
      font-family: var(--font-mono);
    }

    .doc-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .doc-item {
      border-bottom: 1px solid var(--border-soft);
    }

    .doc-item:first-child {
      border-top: 1px solid var(--border-soft);
    }

    .doc-link {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 1rem;
      align-items: baseline;
      padding: 0.75rem 0.5rem;
      text-decoration: none;
      color: inherit;
      transition: background 0.1s;
    }

    .doc-link:hover {
      background: rgba(var(--shadow-rgb), 0.12);
    }

    .doc-title {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--fg);
      line-height: 1.3;
    }

    .doc-link:hover .doc-title {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .doc-date {
      color: var(--fg-subtle);
      font-size: 0.78rem;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }

    @media (max-width: 600px) {
      .folder-title {
        font-size: 1.6rem;
      }

      .doc-link {
        grid-template-columns: 1fr;
        gap: 0.25rem;
      }

      .doc-date {
        font-size: 0.75rem;
      }
    }
  </style>

  <div class="folder-header">
    <h1 class="folder-title">📁 {folderName}</h1>
    <p class="folder-description">{docsInFolder.length} documents</p>
  </div>

  {docsInFolder.length > 0 ? (
    <ol class="doc-list">
      {docsInFolder.map((doc) => {
        const [, slug] = doc.id.split('/');
        return (
          <li class="doc-item">
            <a href={`/folder/${folderId}/${slug}`} class="doc-link">
              <span class="doc-title">{doc.data.title}</span>
              <span class="doc-date">{formatPostDate(doc.data.pubDate)}</span>
            </a>
          </li>
        );
      })}
    </ol>
  ) : (
    <p>No documents yet.</p>
  )}
</Layout>
