---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import galleryScriptUrl from '../../../scripts/gallery.ts?url';

export async function getStaticPaths() {
  const folderDocs = await getCollection('folders', ({ data }) => data.published);

  return folderDocs.map(doc => {
    const [folderId, ...slugParts] = doc.id.split('/');
    const slug = slugParts.join('/');
    return {
      params: { id: folderId, slug },
      props: { doc },
    };
  });
}

const { id: folderId } = Astro.params;
const { doc } = Astro.props;
const { Content, headings } = await render(doc);
const tocHeadings = headings.filter(heading => heading.depth >= 1 && heading.depth <= 3);
const showTocRail = tocHeadings.length >= 3;

const parseLocalDate = (dateString: string) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateString);
  if (!match) return null;
  const [, year, month, day] = match;
  return new Date(Number(year), Number(month) - 1, Number(day));
};
const parseIsoDate = (dateString?: string) => {
  if (!dateString) return undefined;
  const date = new Date(`${dateString}T00:00:00.000Z`);
  return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
};
const publishedTime = parseIsoDate(doc.data.pubDate);
const updatedTime = parseIsoDate(doc.data.updatedDate);
const displayDate = (() => {
  const date = parseLocalDate(doc.data.pubDate);
  return date
    ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).toLowerCase()
    : doc.data.pubDate;
})();
const description = doc.data.description ?? 'a document';
const readingTimeMinutes = (() => {
  const body = typeof doc.body === 'string' ? doc.body.trim() : '';
  const words = body ? body.split(/\s+/).length : 0;
  return Math.max(1, Math.round(words / 200)) || 2;
})();
const wordCount = (() => {
  const body = typeof doc.body === 'string' ? doc.body.trim() : '';
  return body ? body.split(/\s+/).length : undefined;
})();
const readingTimeLabel = (() => {
  if (readingTimeMinutes < 60) {
    return `approx ${readingTimeMinutes}m read`;
  }
  const hours = Math.floor(readingTimeMinutes / 60);
  const minutes = readingTimeMinutes % 60;
  return minutes
    ? `approx ${hours}h ${minutes}m read`
    : `approx ${hours}h read`;
})();

const folderName = folderId ? folderId.replace(/-/g, ' ') : '';
const folderTitle = folderName.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
const pageTitle = `${doc.data.title} — ${folderTitle}`;
---

<style>
:root {
  --content-max-width: 800px;
  --side-gutter: 1rem;
}

html, body {
  margin: 0;
  padding: 0;
  overflow-x: hidden;
}

code,
pre {
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: break-word;
}

.markdown-body {
  line-height: 1.8;
}

.post-title-main {
  font-size: 2.1rem;
  line-height: 1.2;
  margin: 0 0 0.5rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  font-family: var(--font-mono);
  color: var(--fg-strong);
}

.post-description {
  color: var(--fg-muted);
  margin: 0;
  font-size: 0.98rem;
  line-height: 1.7;
  font-family: var(--font-mono);
}

.post-subline {
  margin-bottom: 2rem;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--fg-subtle);
  font-size: 0.85rem;
  letter-spacing: 0.04em;
  font-family: var(--font-mono);
  margin: 0 0 0.6rem;
}

.post-meta-sep {
  color: var(--border-strong);
}

.post-readtime {
  letter-spacing: 0.04em;
}

.folder-context {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.3rem 0.6rem;
  background: var(--surface-soft);
  border: 1px solid var(--border-soft);
  border-radius: 3px;
  font-size: 0.8rem;
  color: var(--fg-subtle);
  text-decoration: none;
  transition: all 0.15s;
}

.folder-context:hover {
  background: var(--surface-elev);
  border-color: var(--border-muted);
  color: var(--fg);
}

.folder-icon {
  font-size: 0.9rem;
}

.toc-rail {
  position: fixed;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100;
  width: 24px;
  padding: 1.2rem 0 1.2rem 0.4rem;
  transition: width 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  overflow: hidden;
  border-radius: 0 8px 8px 0;
}

.toc-rail:hover {
  width: 280px;
  background: var(--bg);
  box-shadow: 2px 0 16px rgba(var(--shadow-rgb), 0.24);
  padding: 1.2rem 0.8rem 1.2rem 0.8rem;
}

.toc-entries {
  list-style: none;
  padding: 0;
  margin: 0;
}

.toc-entry {
  margin: 0;
}

.toc-entry a {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  padding: 0.25rem 0;
  transition: color 0.15s;
}

.toc-tick {
  flex-shrink: 0;
  height: 2px;
  background: var(--border-strong);
  border-radius: 1px;
  transition: background 0.2s, width 0.2s;
}

.toc-entry-title .toc-tick { width: 24px; height: 3px; }
.toc-entry-title .toc-label { font-weight: 700; color: var(--fg); }
.toc-entry-title { margin-bottom: 0.3rem; }

.toc-d1 .toc-tick { width: 18px; }
.toc-d2 .toc-tick { width: 11px; }
.toc-d3 .toc-tick { width: 6px; }

.toc-label {
  opacity: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 0.78rem;
  font-family: var(--font-mono);
  color: var(--fg-faint);
  transition: opacity 0.2s ease 0.1s;
}

.toc-rail:hover .toc-label {
  opacity: 1;
}

.toc-entry.toc-active .toc-tick {
  background: var(--accent);
}

.toc-entry.toc-active .toc-label {
  color: var(--fg);
  font-weight: 600;
}

.toc-entry a:hover .toc-label {
  color: var(--accent);
}

.toc-entry a:hover .toc-tick {
  background: var(--accent);
}

.toc-d2 a { padding-left: 0.6rem; }
.toc-d3 a { padding-left: 1.2rem; }

@media (max-width: 1024px) {
  .toc-rail { display: none; }
}

.centered-wrapper {
  display: grid;
  grid-template-columns: minmax(var(--side-gutter), 1fr) min(var(--content-max-width), calc(100% - (var(--side-gutter) * 2))) minmax(var(--side-gutter), 1fr);
  width: 100%;
}

.centered-wrapper > * {
  grid-column: 2;
}

article.post-plain {
  box-shadow: none;
  background: none;
  border: none;
  width: 100%;
  max-width: var(--content-max-width);
  margin: 3rem auto;
  padding: 0;
  box-sizing: border-box;
  padding-left: var(--side-gutter);
  padding-right: var(--side-gutter);
}

article.post-plain :global(img) {
  max-width: 600px;
  width: 100%;
  height: auto;
  display: block;
  margin: 1.5rem auto;
}

article.post-plain :global(img[width]) {
  width: auto;
  max-width: 100%;
}

@media (max-width: 600px) {
  :root {
    --side-gutter: 0.1rem;
  }

  .post-title-main {
    font-size: 1.8rem;
    margin-top: 0.5rem;
  }

  article.post-plain svg {
    height: auto !important;
    font-size: 12px !important;
  }
}
</style>

<Layout
  title={pageTitle}
  description={description}
  ogType="article"
  publishedTime={publishedTime}
  useKatex={doc.data.useKatex}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "home", "item": "https://anuraagw.me" },
      { "@type": "ListItem", "position": 2, "name": folderTitle, "item": `https://anuraagw.me/folder/${folderId}` },
      { "@type": "ListItem", "position": 3, "name": doc.data.title },
    ],
  }}
>
  {showTocRail && (
    <nav class="toc-rail" aria-label="Table of contents">
      <ol class="toc-entries">
        <li class="toc-entry toc-entry-title" data-target="top">
          <a href="#">
            <span class="toc-tick"></span>
            <span class="toc-label">{doc.data.title}</span>
          </a>
        </li>
        {tocHeadings.map(heading => (
          <li class={`toc-entry toc-d${heading.depth}`} data-target={heading.slug}>
            <a href={`#${heading.slug}`}>
              <span class="toc-tick"></span>
              <span class="toc-label">{heading.text}</span>
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )}
  <div class="centered-wrapper">
    <article class="post-plain markdown-body">
      <div class="post-meta">
        <time datetime={doc.data.pubDate}>{displayDate}</time>
        <span class="post-meta-sep">•</span>
        <span class="post-readtime">{readingTimeLabel}</span>
        <span class="post-meta-sep">•</span>
        <a href={`/folder/${folderId}`} class="folder-context">
          <span class="folder-icon">📁</span>
          <span>{folderTitle}</span>
        </a>
      </div>
      <h1 class="post-title-main">{doc.data.title}</h1>
      <div class="post-subline">
        {doc.data.description && (
          <p class="post-description">{doc.data.description}</p>
        )}
      </div>
      <Content />
    </article>
  </div>
  <script type="module" src={galleryScriptUrl}></script>
  <script>
    const tocEntries = [...document.querySelectorAll('.toc-entry')];
    if (tocEntries.length) {
      const topEntry = tocEntries.find((entry) => entry.dataset.target === 'top') ?? null;
      const sectionItems = tocEntries
        .map((entry) => {
          const id = entry.dataset.target;
          if (!id || id === 'top') return null;
          const heading = document.getElementById(id);
          if (!heading) return null;
          return { id, entry, heading };
        })
        .filter(Boolean);

      let active = null;
      let scheduled = false;
      let lockUntil = 0;

      const setActive = (entry) => {
        if (entry === active) return;
        if (active) active.classList.remove('toc-active');
        active = entry;
        if (active) active.classList.add('toc-active');
      };

      const resolveActiveEntry = () => {
        if (!sectionItems.length) return topEntry;
        const scrollTop = window.scrollY;
        if (scrollTop <= 24) return topEntry;

        let current = topEntry;
        for (const item of sectionItems) {
          const headingTop = window.scrollY + item.heading.getBoundingClientRect().top;
          if (headingTop <= scrollTop + 96) current = item.entry;
          else break;
        }
        return current;
      };

      const updateActive = () => {
        scheduled = false;
        if (Date.now() < lockUntil) return;
        setActive(resolveActiveEntry());
      };

      const scheduleUpdate = () => {
        if (scheduled) return;
        scheduled = true;
        requestAnimationFrame(updateActive);
      };

      window.addEventListener('scroll', scheduleUpdate, { passive: true });
      window.addEventListener('resize', scheduleUpdate, { passive: true });
      window.addEventListener('load', scheduleUpdate, { once: true });
      scheduleUpdate();

      for (const entry of tocEntries) {
        entry.querySelector('a')?.addEventListener('click', (event) => {
          const target = entry.dataset.target;
          if (!target) return;

          event.preventDefault();
          setActive(entry);
          lockUntil = Date.now() + 800;

          if (target === 'top') {
            window.scrollTo({ top: 0 });
          } else {
            const heading = document.getElementById(target);
            if (!heading) return;
            heading.scrollIntoView({ block: 'start' });
          }
        });
      }
    }
  </script>
</Layout>
