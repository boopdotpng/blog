---
import Layout from '../layouts/Layout.astro';
import Home from '../components/Home.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => data.published);
const sortedPosts = [...posts].sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const site = Astro.site ?? new URL('https://anuraagw.me');
const homeUrl = new URL('/', site).toString();
const homeSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${homeUrl}#collection`,
  url: homeUrl,
  name: 'anuraag — notes',
  description: 'Field notes on systems, ML, GPUs, and biology, plus reverse engineering writeups and project updates.',
  mainEntity: {
    '@type': 'ItemList',
    itemListOrder: 'https://schema.org/ItemListOrderDescending',
    numberOfItems: sortedPosts.length,
    itemListElement: sortedPosts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: new URL(`/blog/${post.id}`, site).toString(),
      name: post.data.title,
      description: post.data.description,
    })),
  },
};
const favoriteSong = {
  title: 'journey of a lifetime ~ frieren main theme',
  url: 'https://open.spotify.com/track/1FhWuo97KqSWbe4UYpKAei',
};

// Category legend for the sidebar — counts derived from posts, sorted by frequency.
const catCounts = sortedPosts.reduce<Record<string, number>>((acc, post) => {
  const cat = post.data.cat ?? 'misc';
  acc[cat] = (acc[cat] ?? 0) + 1;
  return acc;
}, {});
const categories = Object.entries(catCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([name, count]) => ({ name, count }));

// Edit this line to change the "now" blurb in the sidebar.
const now = 'bringing up llama3 end-to-end on a single tenstorrent blackhole card';
---

<Layout
  title="notes"
  description="Field notes on systems, ML, GPUs, and biology, plus reverse engineering writeups and project updates."
  schema={homeSchema}
  favoriteSong={favoriteSong}
  categories={categories}
  now={now}
>
  <Home posts={sortedPosts} />
</Layout>
