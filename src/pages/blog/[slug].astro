---
// layout + content loading
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import galleryScriptUrl from '../../scripts/gallery.ts?url';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.published);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter(heading => heading.depth >= 1 && heading.depth <= 3);
const showTocRail = tocHeadings.length >= 3;

const parseLocalDate = (dateString: string) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateString);
  if (!match) return null;
  const [, year, month, day] = match;
  return new Date(Number(year), Number(month) - 1, Number(day));
};
const parseIsoDate = (dateString?: string) => {
  if (!dateString) return undefined;
  const date = new Date(`${dateString}T00:00:00.000Z`);
  return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
};
const publishedTime = parseIsoDate(post.data.pubDate);
const updatedTime = parseIsoDate(post.data.updatedDate);
const pubDate = parseLocalDate(post.data.pubDate);
const displayDate = pubDate
  ? pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).toLowerCase()
  : post.data.pubDate;
const description = post.data.description ?? 'a short post on something';
const body = typeof post.body === 'string' ? post.body.trim() : '';
const wordCount = body ? body.split(/\s+/).length : 0;
const multiplier = post.data.cat === 'code' ? 1.3 : 1;
const readingTimeMinutes = Math.max(1, Math.round((wordCount / 200) * multiplier));
const readingTimeLabel = readingTimeMinutes < 60
  ? `approx ${readingTimeMinutes}m read`
  : `approx ${Math.floor(readingTimeMinutes / 60)}h${readingTimeMinutes % 60 ? ` ${readingTimeMinutes % 60}m` : ''} read`;
---
<style>
:root {
  /* adjust these to taste */
  --content-max-width: 700px;
  --side-gutter: 1rem;
}

/* prevent any accidental overflow */
html, body {
  margin: 0;
  padding: 0;
  overflow-x: hidden;
}

/* code blocks scroll horizontally rather than wrapping (preserves indentation) */
pre {
  white-space: pre;
}

/* inline code may still break to avoid overflow */
:not(pre) > code {
  word-break: break-word;
  overflow-wrap: break-word;
}

/* body text line height */
.markdown-body {
  line-height: 1.8;
}

/* Post title styling */
.post-title-main {
  font-size: 2.1rem;
  line-height: 1.2;
  margin: 0 0 0.5rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  font-family: var(--font-mono);
  color: var(--fg-strong);
}

.post-description {
  color: var(--fg-muted);
  margin: 0;
  font-size: 0.98rem;
  line-height: 1.7;
  font-family: var(--font-mono);
}

.post-subline {
  margin-bottom: 2rem;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--fg-subtle);
  font-size: 0.85rem;
  letter-spacing: 0.04em;
  font-family: var(--font-mono);
  margin: 0 0 0.6rem;
}

.post-meta-sep {
  color: var(--border-strong);
}

.post-readtime {
  letter-spacing: 0.04em;
}

@media (max-width: 600px) {
  .post-subline {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .post-meta {
    flex-wrap: wrap;
  }
}

/* --- Sidebar table of contents --- */
.toc-rail {
  position: fixed;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100;
  width: 24px;
  max-height: calc(100vh - 2rem);
  padding: 1.2rem 0 1.2rem 0.4rem;
  transition: width 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  overflow-x: hidden;
  overflow-y: auto;
  scrollbar-width: thin;
  border-radius: 0 8px 8px 0;
}

.toc-rail:hover,
.toc-rail:focus-within {
  width: 280px;
  background: var(--bg);
  box-shadow: 2px 0 16px rgba(var(--shadow-rgb), 0.24);
  padding: 1.2rem 0.8rem 1.2rem 0.8rem;
}

.toc-entries {
  list-style: none;
  padding: 0;
  margin: 0;
}

.toc-entry {
  margin: 0;
}

.toc-entry a {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  padding: 0.25rem 0;
  transition: color 0.15s;
}

.toc-tick {
  flex-shrink: 0;
  height: 2px;
  background: var(--border-strong);
  border-radius: 1px;
  transition: background 0.2s, width 0.2s;
}

.toc-entry-title .toc-tick { width: 24px; height: 3px; }
.toc-entry-title .toc-label { font-weight: 700; color: var(--fg); }
.toc-entry-title { margin-bottom: 0.3rem; }

.toc-d1 .toc-tick { width: 18px; }
.toc-d2 .toc-tick { width: 11px; }
.toc-d3 .toc-tick { width: 6px; }

.toc-label {
  opacity: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 0.78rem;
  font-family: var(--font-mono);
  color: var(--fg-faint);
  transition: opacity 0.2s ease 0.1s;
}

.toc-rail:hover .toc-label,
.toc-rail:focus-within .toc-label {
  opacity: 1;
}

/* Active heading */
.toc-entry.toc-active .toc-tick {
  background: var(--accent);
}

.toc-entry.toc-active .toc-label {
  color: var(--fg);
  font-weight: 600;
}

/* Hover on individual items */
.toc-entry a:hover .toc-label {
  color: var(--accent);
}

.toc-entry a:hover .toc-tick {
  background: var(--accent);
}

/* Depth indentation (only visible when expanded) */
.toc-d2 a { padding-left: 0.6rem; }
.toc-d3 a { padding-left: 1.2rem; }

/* --- Tap-to-toggle controls (touch / narrow screens only) --- */
.toc-toggle { display: none; }
.toc-backdrop { display: none; }

/* On wide screens the rail is hover-driven; below that it becomes a
   tap-to-toggle panel with a floating button and a backdrop. */
@media (max-width: 1024px) {
  /* Rail off-canvas by default, slides in when toggled open */
  .toc-rail {
    width: 280px;
    max-width: calc(100vw - 4rem);
    padding: 1.2rem 0.8rem;
    background: var(--bg);
    box-shadow: 2px 0 16px rgba(var(--shadow-rgb), 0.24);
    border-radius: 0 12px 12px 0;
    transform: translateY(-50%) translateX(-100%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: transform 0.28s ease, opacity 0.28s ease, visibility 0.28s;
  }

  .toc-rail.is-open {
    transform: translateY(-50%) translateX(0);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* labels are always shown inside the toggled panel */
  .toc-label { opacity: 1; }

  /* Floating toggle button */
  .toc-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 101;
    width: 46px;
    height: 46px;
    padding: 0;
    border: 1px solid var(--border-strong);
    border-radius: 50%;
    background: var(--bg);
    color: var(--fg);
    box-shadow: 0 2px 12px rgba(var(--shadow-rgb), 0.24);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .toc-toggle svg { width: 20px; height: 20px; display: block; }
  .toc-toggle .toc-toggle-close { display: none; }

  .toc-toggle.is-active {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }
  .toc-toggle.is-active .toc-toggle-open { display: none; }
  .toc-toggle.is-active .toc-toggle-close { display: block; }

  /* Dismiss backdrop */
  .toc-backdrop {
    display: block;
    position: fixed;
    inset: 0;
    z-index: 99;
    background: rgba(var(--shadow-rgb), 0.32);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.28s ease, visibility 0.28s;
  }
  .toc-backdrop.is-open {
    opacity: 1;
    visibility: visible;
  }
}

/* Perfect centering wrapper */
.centered-wrapper {
  display: grid;
  grid-template-columns: minmax(var(--side-gutter), 1fr) min(var(--content-max-width), calc(100% - (var(--side-gutter) * 2))) minmax(var(--side-gutter), 1fr);
  width: 100%;
}

.centered-wrapper > * {
  grid-column: 2;
}

/* main article container */
article.post-plain {
  box-shadow: none;
  background: none;
  border: none;

  /* fluid width up to a max, centered */
  width: 100%;
  max-width: var(--content-max-width);
  margin: 3rem auto;         /* top/bottom breathing room, centered */
  padding: 0;                /* remove side padding */
  box-sizing: border-box;
  
  /* Apply equal padding left and right for better centering */
  padding-left: var(--side-gutter);
  padding-right: var(--side-gutter);
}

article.post-plain :global(img) {
  max-width: 600px;
  width: 100%;
  height: auto;
  display: block;
  margin: 1.5rem auto;
}
article.post-plain :global(img[width]) {
  width: auto;
  max-width: 100%;
}

/* tweak typography on small screens if you like */
@media (max-width: 600px) {
  :root {
    --side-gutter: 0.1rem;  /* 50% of the original 1rem */
  }
  
  .post-title-main {
    font-size: 1.8rem;
    margin-top: 0.5rem;
  }
  .post-date-main {
    font-size: 0.95rem;
  }
  
  /* Better SVG handling for mobile */
  article.post-plain svg {
    height: auto !important;  /* Override any inline height */
    font-size: 12px !important; /* Slightly reduce SVG text size on mobile */
  }
}
</style>

<Layout
  title={post.data.title}
  description={description}
  ogType="article"
  useKatex={post.data.useKatex}
  ogImage={`/og/${post.id}.png`}
  schemaArticle={{
    title: post.data.title,
    description,
    publishedTime,
    updatedTime,
    section: post.data.cat,
    wordCount: wordCount || undefined,
    imageUrl: new URL(`/og/${post.id}.png`, Astro.site ?? 'https://anuraagw.me').href,
  }}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "home", "item": "https://anuraagw.me" },
      { "@type": "ListItem", "position": 2, "name": post.data.title },
    ],
  }}
>
  {showTocRail && (
    <Fragment>
      <button
        class="toc-toggle"
        type="button"
        aria-label="Toggle table of contents"
        aria-expanded="false"
        aria-controls="toc-rail"
      >
        <svg class="toc-toggle-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="8" y1="6" x2="21" y2="6" />
          <line x1="8" y1="12" x2="21" y2="12" />
          <line x1="8" y1="18" x2="21" y2="18" />
          <circle cx="3.5" cy="6" r="1" fill="currentColor" stroke="none" />
          <circle cx="3.5" cy="12" r="1" fill="currentColor" stroke="none" />
          <circle cx="3.5" cy="18" r="1" fill="currentColor" stroke="none" />
        </svg>
        <svg class="toc-toggle-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </button>
      <div class="toc-backdrop"></div>
      <nav id="toc-rail" class="toc-rail" aria-label="Table of contents">
        <ol class="toc-entries">
        <li class="toc-entry toc-entry-title" data-target="top">
          <a href="#">
            <span class="toc-tick"></span>
            <span class="toc-label">{post.data.title}</span>
          </a>
        </li>
        {tocHeadings.map(heading => (
          <li class={`toc-entry toc-d${heading.depth}`} data-target={heading.slug}>
            <a href={`#${heading.slug}`}>
              <span class="toc-tick"></span>
              <span class="toc-label">{heading.text}</span>
            </a>
          </li>
          ))}
        </ol>
      </nav>
    </Fragment>
  )}
  <div class="centered-wrapper">
    <article class="post-plain markdown-body">
      <div class="post-meta">
        <time datetime={post.data.pubDate}>{displayDate}</time>
        <span class="post-meta-sep">•</span>
        <span class="post-readtime">{readingTimeLabel}</span>
      </div>
      <h1 class="post-title-main">{post.data.title}</h1>
      <div class="post-subline">
        {post.data.description && (
          <p class="post-description">{post.data.description}</p>
        )}
      </div>
      <Content />
    </article>
  </div>
  <script type="module" src={galleryScriptUrl}></script>
  <script>
    const tocEntries = [...document.querySelectorAll('.toc-entry')];
    if (tocEntries.length) {
      // --- tap-to-toggle panel (touch / narrow screens) ---
      const tocRail = document.getElementById('toc-rail');
      const tocToggle = document.querySelector('.toc-toggle');
      const tocBackdrop = document.querySelector('.toc-backdrop');
      const narrowQuery = window.matchMedia('(max-width: 1024px)');

      const isTocOpen = () => !!tocRail?.classList.contains('is-open');
      const setTocOpen = (open) => {
        tocRail?.classList.toggle('is-open', open);
        tocBackdrop?.classList.toggle('is-open', open);
        tocToggle?.classList.toggle('is-active', open);
        tocToggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
      };
      const closeToc = () => setTocOpen(false);

      tocToggle?.addEventListener('click', () => setTocOpen(!isTocOpen()));
      tocBackdrop?.addEventListener('click', closeToc);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && isTocOpen()) closeToc();
      });
      // reset when returning to the desktop hover layout
      narrowQuery.addEventListener('change', (event) => {
        if (!event.matches) closeToc();
      });

      const topEntry = tocEntries.find((entry) => entry.dataset.target === 'top') ?? null;
      const sectionItems = tocEntries
        .map((entry) => {
          const id = entry.dataset.target;
          if (!id || id === 'top') return null;
          const heading = document.getElementById(id);
          if (!heading) return null;
          return { id, entry, heading };
        })
        .filter(Boolean);

      let active = null;
      let scheduled = false;
      let lockUntil = 0;

      const setActive = (entry) => {
        if (entry === active) return;
        if (active) active.classList.remove('toc-active');
        active = entry;
        if (active) active.classList.add('toc-active');
      };

      const resolveActiveEntry = () => {
        if (!sectionItems.length) return topEntry;
        const scrollTop = window.scrollY;
        if (scrollTop <= 24) return topEntry;

        let current = topEntry;
        for (const item of sectionItems) {
          const headingTop = window.scrollY + item.heading.getBoundingClientRect().top;
          if (headingTop <= scrollTop + 96) current = item.entry;
          else break;
        }
        return current;
      };

      const updateActive = () => {
        scheduled = false;
        if (Date.now() < lockUntil) return;
        setActive(resolveActiveEntry());
      };

      const scheduleUpdate = () => {
        if (scheduled) return;
        scheduled = true;
        requestAnimationFrame(updateActive);
      };

      window.addEventListener('scroll', scheduleUpdate, { passive: true });
      window.addEventListener('resize', scheduleUpdate, { passive: true });
      window.addEventListener('load', scheduleUpdate, { once: true });
      scheduleUpdate();

      for (const entry of tocEntries) {
        entry.querySelector('a')?.addEventListener('click', (event) => {
          const target = entry.dataset.target;
          if (!target) return;

          event.preventDefault();
          setActive(entry);
          lockUntil = Date.now() + 800;
          if (narrowQuery.matches) closeToc();

          if (target === 'top') {
            window.scrollTo({ top: 0 });
          } else {
            const heading = document.getElementById(target);
            if (!heading) return;
            heading.scrollIntoView({ block: 'start' });
          }
        });
      }
    }
  </script>
</Layout>
