---
import '../styles/diagrams.css';
// Normalize the path so it works in both `astro dev` (pathname "/") and the
// static build, which uses `build.format: 'file'` and yields "/index.html".
const cleanPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '')
  .replace(/\/$/, '') || '/';
const isHome = cleanPath === '/';
const {
  title = 'ml, bio, coding',
  description = 'thoughts on neural nets, chips, and cells',
  ogType = 'website',
  schemaArticle,
  schema,
  favoriteSong,
  categories = [],
  now,
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  useKatex = false,
  ogImage,
  fullBleed = false,
  hideBackLink = false,
} = Astro.props;

const siteName = 'anuraag';
const siteHandle = '@boopdotpng';
const authorName = 'Anuraag Warudkar';
const fullTitle = title;
const canonicalUrl = Astro.site ? new URL(cleanPath, Astro.site).toString() : Astro.url.toString();
const siteUrl = Astro.site ? new URL('/', Astro.site).toString() : canonicalUrl;
const ogImageUrl = ogImage
  ? (Astro.site ? new URL(ogImage, Astro.site).toString() : ogImage)
  : (Astro.site ? new URL('/favicon.ico', Astro.site).toString() : '/favicon.ico');
const twitterCard = ogImage ? 'summary_large_image' : 'summary';
const extraSchemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}#person`,
  "name": authorName,
  "alternateName": ["anuraag", "anuraagw"],
  "url": siteUrl,
  "sameAs": [
    "https://github.com/boopdotpng",
    "https://twitter.com/boopdotpng"
  ],
  "jobTitle": "Software Engineer"
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}#website`,
  "name": siteName,
  "url": siteUrl,
  "publisher": { "@id": `${siteUrl}#person` }
};
const pageSchema = {
  "@context": "https://schema.org",
  "@type": isHome ? "CollectionPage" : "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  "url": canonicalUrl,
  "name": fullTitle,
  "description": description,
  "inLanguage": "en-US",
  "isPartOf": { "@id": `${siteUrl}#website` },
  "about": { "@id": `${siteUrl}#person` }
};
let articleSchema = schemaArticle ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": schemaArticle.title,
  "description": schemaArticle.description,
  "datePublished": schemaArticle.publishedTime,
  "dateModified": schemaArticle.updatedTime ?? schemaArticle.publishedTime,
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
  "author": { "@id": `${siteUrl}#person` },
  "publisher": {
    "@type": "Person",
    "name": authorName,
    "url": siteUrl
  },
  "inLanguage": "en-US",
  "isPartOf": { "@id": `${siteUrl}#website` }
} : null;
if (articleSchema && schemaArticle?.imageUrl) {
  articleSchema = { ...articleSchema, image: [schemaArticle.imageUrl] };
}
if (articleSchema && schemaArticle?.section) {
  articleSchema = { ...articleSchema, articleSection: schemaArticle.section };
}
if (articleSchema && schemaArticle?.wordCount) {
  articleSchema = { ...articleSchema, wordCount: schemaArticle.wordCount };
}
---
<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content={authorName} />
  <meta name="robots" content={robots} />

  <title>{fullTitle}</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="preload" href="/fonts/GoogleSansCode-Variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/GoogleSansCode-VariableItalic.woff2" as="font" type="font/woff2" crossorigin />
  {useKatex && <link rel="stylesheet" href="/katex.min.css" />}
  <link rel="stylesheet" href="/markdown.css" />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:alt" content={fullTitle} />
  {ogImage && <meta property="og:image:width" content="1200" />}
  {ogImage && <meta property="og:image:height" content="630" />}
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="anuraag" />
  {schemaArticle?.publishedTime && <meta property="article:published_time" content={schemaArticle.publishedTime} />}
  {schemaArticle?.updatedTime && <meta property="article:modified_time" content={schemaArticle.updatedTime} />}
  {schemaArticle?.section && <meta property="article:section" content={schemaArticle.section} />}

  <meta name="twitter:card" content={twitterCard} />
  <meta name="twitter:site" content={siteHandle} />
  <meta name="twitter:creator" content={siteHandle} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <meta name="twitter:image:alt" content={fullTitle} />
  {ogType === 'article' && <meta property="article:author" content={authorName} />}
  <meta name="theme-color" content="#111" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#fff" media="(prefers-color-scheme: light)" />

  <script is:inline>
    (() => {
      const storedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = storedTheme === 'light' || storedTheme === 'dark'
        ? storedTheme
        : (prefersDark ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    })();
  </script>

<style>
  @font-face {
    font-family: "Google Sans Code";
    font-style: normal;
    font-weight: 300 800;
    font-display: swap;
    src: url("/fonts/GoogleSansCode-Variable.woff2") format("woff2"),
         url("/fonts/GoogleSansCode-Variable.ttf") format("truetype");
  }

  @font-face {
    font-family: "Google Sans Code";
    font-style: italic;
    font-weight: 300 800;
    font-display: swap;
    src: url("/fonts/GoogleSansCode-VariableItalic.woff2") format("woff2"),
         url("/fonts/GoogleSansCode-VariableItalic.ttf") format("truetype");
  }

  :root {
    --bg: #faf9f7;
    --fg: #37352f;
    --fg-strong: #1a1a1a;
    --fg-soft: #666055;
    --fg-muted: #888178;
    --fg-faint: #999188;
    --fg-subtle: #aaa39b;
    --accent: #4a7c96;
    --accent-hover: #3a6580;
    --accent-rgb: 74, 124, 150;
    --border-soft: #e8e6e1;
    --border-muted: #e0ddd8;
    --border-strong: #d0cdc6;
    --surface-soft: #f5f3ef;
    --surface-elev: #f0eeeb;
    --surface-note: #f7f6f3;
    --cat-gpu: #3a8a6e;
    --cat-ml: #c06a20;
    --cat-hardware: #b85a8a;
    --cat-tenstorrent: #3e8db0;
    --cat-bio: #7c6ab8;
    --cat-misc: #7a8694;
    /* semantic aliases used by inline diagrams (kernel pipeline, etc.) */
    --cat-host: #4a7c96;
    --cat-dispatch: #c06a20;
    --cat-worker: #7c6ab8;
    --cat-green: #3a8a6e;
    --shadow-rgb: 0, 0, 0;
    --overlay-bg: rgba(0, 0, 0, 0.72);
    --overlay-control-bg: rgba(0, 0, 0, 0.55);
    --overlay-control-border: rgba(255, 255, 255, 0.18);
    --overlay-text: rgba(255, 255, 255, 0.9);
    --overlay-text-muted: rgba(255, 255, 255, 0.75);
    --font-size: 16px;
    --font-sans: Charter, "Bitstream Charter", "Sitka Text", Cambria, serif;
    --font-mono: "Google Sans Code", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    /* theme cross-fade + toggle animation timing */
    --theme-dur: 0.7s;
    --theme-ease: cubic-bezier(0.45, 0, 0.2, 1);
    --toggle-dur: 0.55s;
    --toggle-ease: cubic-bezier(0.34, 1.2, 0.64, 1);
    color-scheme: light;
  }

  :root[data-theme='dark'] {
    --bg: #181818;
    --fg: #c8c4be;
    --fg-strong: #e8e5df;
    --fg-soft: #9a9590;
    --fg-muted: #7a7570;
    --fg-faint: #6a6560;
    --fg-subtle: #5a5550;
    --accent: #8ab4cc;
    --accent-hover: #a0c8dd;
    --accent-rgb: 138, 180, 204;
    --border-soft: #2a2a28;
    --border-muted: #333330;
    --border-strong: #444440;
    --surface-soft: #1e1e1c;
    --surface-elev: #242422;
    --surface-note: #282826;
    --cat-gpu: #6dba98;
    --cat-ml: #daa86a;
    --cat-hardware: #d49ab8;
    --cat-tenstorrent: #84c2de;
    --cat-bio: #a89cd6;
    --cat-misc: #98a4b0;
    --cat-host: #8ab4cc;
    --cat-dispatch: #daa86a;
    --cat-worker: #a89cd6;
    --cat-green: #6dba98;
    --shadow-rgb: 8, 8, 6;
    --overlay-bg: rgba(12, 12, 10, 0.8);
    --overlay-control-bg: rgba(22, 22, 20, 0.72);
    --overlay-control-border: rgba(200, 196, 190, 0.2);
    --overlay-text: rgba(232, 229, 223, 0.94);
    --overlay-text-muted: rgba(200, 196, 190, 0.75);
    color-scheme: dark;
  }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans);
    line-height: 1.5;
    font-size: var(--font-size);
    transition: background-color var(--theme-dur) var(--theme-ease), color var(--theme-dur) var(--theme-ease);
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  html.theme-changing,
  html.theme-changing * {
    transition-property: color, background-color, border-color, box-shadow, text-shadow, fill, stroke;
    transition-duration: var(--theme-dur);
    transition-timing-function: var(--theme-ease);
  }

  code, pre, kbd, samp {
    font-family: var(--font-mono);
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem clamp(1rem, 4vw, 2rem);
    box-sizing: border-box;
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    font-family: var(--font-mono);
  }

  .site-header.full-bleed {
    max-width: none;
    margin: 0;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .home-song {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--fg-faint);
    text-decoration: none;
  }

  .home-song:hover .song-title {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .song-icon {
    color: var(--fg-subtle);
  }

  .song-title {
    color: var(--fg-soft);
    letter-spacing: 0.02em;
    transition: color var(--theme-dur) var(--theme-ease);
  }

  .site-title {
    font-size: 0.85rem;
    font-weight: 700;
    margin: 0;
    text-transform: lowercase;
    letter-spacing: 0.1em;
  }

  .site-title a {
    color: var(--fg);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .site-title a:hover {
    text-decoration: none;
  }

  .site-title a:hover .site-label {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .site-title a .arrow {
    font-size: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 1em;
    line-height: 1;
    color: var(--fg-subtle);
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  nav a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.82rem;
    padding: 0.35rem 0.6rem;
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  nav a:hover {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .theme-toggle {
    border: none;
    background: none;
    padding: 0.35rem 0.4rem;
    line-height: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    -webkit-tap-highlight-color: transparent;
  }

  .theme-toggle-track {
    position: relative;
    display: inline-block;
    width: 34px;
    height: 18px;
    border-radius: 999px;
    background: var(--surface-elev);
    border: 1px solid var(--border-strong);
    transition: background-color var(--theme-dur) var(--theme-ease), border-color var(--theme-dur) var(--theme-ease);
  }

  .theme-toggle:hover .theme-toggle-track {
    border-color: var(--fg-subtle);
  }

  .theme-toggle:focus-visible {
    outline: none;
  }

  .theme-toggle:focus-visible .theme-toggle-track {
    outline: 2px solid rgba(var(--accent-rgb), 0.5);
    outline-offset: 2px;
  }

  .theme-toggle-thumb {
    position: absolute;
    top: 1px;
    left: 1px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg);
    color: var(--fg-soft);
    display: grid;
    place-items: center;
    box-shadow: 0 1px 2px rgba(var(--shadow-rgb), 0.25);
    transition: transform var(--toggle-dur) var(--toggle-ease), background-color var(--theme-dur) var(--theme-ease), color var(--theme-dur) var(--theme-ease);
  }

  :root[data-theme='dark'] .theme-toggle-thumb {
    transform: translateX(16px);
  }

  .theme-icon {
    position: absolute;
    transition: opacity calc(var(--toggle-dur) * 0.7) ease, transform var(--toggle-dur) var(--toggle-ease);
  }

  .theme-icon-moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }

  :root[data-theme='dark'] .theme-icon-sun {
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }

  :root[data-theme='dark'] .theme-icon-moon {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    html,
    body,
    html.theme-changing,
    html.theme-changing *,
    .song-title,
    .theme-toggle,
    .theme-toggle-track,
    .theme-toggle-thumb,
    .theme-icon {
      transition: none !important;
    }
  }

  .page-main {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 2rem);
  }

  .page-main.full-bleed {
    max-width: none;
    margin: 0;
    padding: 0;
  }

  /* Blog post pages get slightly different treatment */
  .page-main:has(.post-content) {
    padding-bottom: 4rem;
  }

  /* Global keyboard focus indicator (low specificity so per-element
     focus styles can still override) */
  :where(a, button, [tabindex]):focus-visible {
    outline: 2px solid rgba(var(--accent-rgb), 0.5);
    outline-offset: 2px;
  }

  .site-footer {
    max-width: 800px;
    margin: 3.5rem auto 0;
    padding: 1.5rem clamp(1rem, 4vw, 2rem) 2.5rem;
    box-sizing: border-box;
    width: 100%;
    border-top: 1px solid var(--border-soft);
    font-family: var(--font-mono);
  }

  .site-footer.full-bleed {
    max-width: none;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
  }

  .footer-nav a {
    color: var(--fg-muted);
    text-decoration: none;
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  .footer-nav a:hover {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-sep {
    color: var(--border-strong);
  }

  /* ── home: sidebar card + index ─────────────────────────── */

  .home-shell {
    display: flex;
    flex: 1;
    min-height: 100vh;
    align-items: stretch;
    gap: clamp(1.5rem, 4vw, 3rem);
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 2rem);
    box-sizing: border-box;
  }

  .home-sidebar {
    flex: 0 0 230px;
    display: flex;
  }

  .home-card {
    position: sticky;
    top: clamp(1.5rem, 4vw, 3rem);
    align-self: flex-start;
    width: 100%;
    min-height: calc(100vh - 2 * clamp(1.5rem, 4vw, 3rem));
    max-height: calc(100vh - 2 * clamp(1.5rem, 4vw, 3rem));
    overflow: auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.5rem 1.4rem;
    box-sizing: border-box;
    border: 1px solid var(--border-muted);
    border-radius: 14px;
    background: var(--surface-soft);
    font-family: var(--font-mono);
  }

  .home-name {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    color: var(--fg-strong);
    text-decoration: none;
  }

  .home-name:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .home-card .home-song {
    display: block;
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .home-card .home-song .song-icon {
    display: inline-block;
    vertical-align: -0.15em;
    margin-right: 0.35rem;
  }

  .home-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 0.1rem;
  }

  .home-controls .theme-toggle {
    padding: 0;
  }

  .home-theme-label {
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    text-transform: lowercase;
  }

  .home-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
  }

  .home-nav a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.82rem;
    padding: 0.2rem 0;
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  .home-nav a:hover {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .home-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .home-block-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: lowercase;
    color: var(--fg-subtle);
  }

  .home-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .home-tag {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.8rem;
    color: var(--fg-soft);
    cursor: default;
    transition: color 0.15s;
    padding: 0.25rem 0;
  }

  .home-tag:hover {
    color: var(--fg);
  }

  .home-tag-dot {
    width: 9px;
    height: 9px;
    border-radius: 2px;
    flex: none;
  }

  .home-tag-name {
    text-transform: lowercase;
  }

  .home-tag-count {
    margin-left: auto;
    font-size: 0.72rem;
    color: var(--fg-faint);
    font-variant-numeric: tabular-nums;
  }

  .home-now {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--fg-soft);
  }

  .home-layout {
    position: relative;
    display: flex;
    flex-direction: column;
    flex: 1;
    width: 100%;
    overflow: hidden;
  }

  .home-cat {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    margin: 0;
    width: 100%;
    font-family: var(--font-mono);
    font-size: clamp(0.4rem, 1vw, 0.78rem);
    line-height: 1.2;
    color: var(--fg);
    opacity: 0.4;
    white-space: pre;
    overflow: hidden;
    text-align: center;
    pointer-events: none;
  }

  .home-content {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
  }

  @media (max-width: 760px) {
    .home-shell {
      flex-direction: column;
      min-height: 0;
      gap: 1.25rem;
      padding: 1.25rem 1rem 2.5rem;
    }

    .home-sidebar {
      flex: none;
      width: auto;
    }

    .home-card {
      position: static;
      min-height: 0;
      max-height: none;
      overflow: visible;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem 1.25rem;
    }

    .home-name {
      flex-basis: 100%;
    }

    .home-card .home-song {
      flex-basis: 100%;
    }

    .home-nav {
      flex-direction: row;
      gap: 0.9rem;
    }

    .home-block {
      flex-basis: 100%;
    }

    .home-tags {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.4rem 1.1rem;
    }

    .home-tag-count {
      margin-left: 0.35rem;
    }

    .home-layout {
      overflow: visible;
    }

    .home-cat {
      position: static;
      bottom: auto;
      padding: 0 1rem 1.5rem;
    }
  }

</style>

  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
  {extraSchemas.map((entry) => (
    <script type="application/ld+json" set:html={JSON.stringify(entry)} />
  ))}

</head>
