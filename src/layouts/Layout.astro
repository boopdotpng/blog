---
const isHome = Astro.url.pathname === '/';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={Astro.props.description ?? 'thoughts on neural nets, chips, and cells'} />
  
    <title>{Astro.props.title ?? 'ml, bio, coding | anuraag'}</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="stylesheet" href="/katex.min.css" />
    <link rel="stylesheet" href="/markdown.css" />
  
    <meta property="og:title" content={Astro.props.title ?? 'ml, bio, coding | anuraag'} />
    <meta property="og:description" content={Astro.props.description ?? 'thoughts on neural nets, chips, and cells'} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://anuraagw.me" />
    <meta property="og:image" content="https://anuraagw.me/preview.png" />
  
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={Astro.props.title ?? 'ml, bio, coding | anuraag'} />
    <meta name="twitter:description" content={Astro.props.description ?? 'thoughts on neural nets, chips, and cells'} />
    <meta name="twitter:image" content="https://anuraagw.me/preview.png" />
  
<style>
  :root {
    --accent: #58a6ff;
    --font-size: 16px;
    --code-border: #d0d7de;
    --bg: #fffdf4;
    --fg: #0a0a0a;
    --fg-muted: #666666;
    --fg-subtle: #999999;
    --border: #e0e0e0;
    --hover-bg: #f5f5f5;
    --card-hover: rgba(0, 0, 0, 0.04);
    --code-bg: #f5f7fb;
    --code-fg: #1f2328;
    --table-border: #cccccc;
    --table-header-bg: #f0f0f0;
    --table-row-border: #e8e8e8;
    --scrollbar-thumb: #cccccc;
    --scrollbar-track: #f0f0f0;
    --link-color: #0066cc;
  }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: system-ui, sans-serif;
    line-height: 1.5;
    font-size: var(--font-size);
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 5vh;
    padding: 0 1rem;
    box-sizing: border-box;
  }

  .site-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
  }

  .site-title a {
    color: var(--fg);
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .site-title a .arrow {
    margin-right: 0.4rem;
    font-size: 0.9rem;
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  nav a {
    color: var(--fg);
    text-decoration: underline;
    font-size: 0.9rem;
  }

  main {
    max-width: clamp(720px, 80%, 960px);
    margin: 2rem auto;
    padding: 0 clamp(1rem, 4vw, 2rem);
  }

  .post-card {
    display: block;
    padding: 1rem;
    margin-bottom: 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: background 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .post-card:hover {
    background: var(--hover-bg);
  }
</style>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Anuraag Warudkar",
      "alternateName": ["anuraag", "anuraagw"],
      "url": "https://anuraagw.me",
      "sameAs": [
        "https://github.com/boopdotpng",
        "https://twitter.com/boopdotpng"
      ],
      "jobTitle": "Software Engineer"
    }
    </script>

</head>
<body>
  <header>
    <div class="site-title">
      <a href="/">
        {!isHome && <span class="arrow">&#8592;</span>}
        anuraag
      </a>
    </div>
    <nav>
      <ul>
        <li><a href="https://twitter.com/boopdotpng" target="_blank">twitter</a></li>
        <li><a href="https://github.com/boopdotpng" target="_blank">github</a></li>
      </ul>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  
</body>
</html>
