  <script is:inline>
    (() => {
      // Longcat: body stretches to fill the row, blinks now and then,
      // and sleeps while the dark theme is on. Static markup is the no-JS fallback.
      const cat = document.querySelector('.home-cat');
      if (!cat) return;

      const root = document.documentElement;
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      let eyes = ['o.o', 'o.o'];

      const measureCharWidth = () => {
        const probe = document.createElement('span');
        probe.textContent = '_'.repeat(100);
        probe.style.cssText = 'visibility:hidden;position:absolute;white-space:pre;';
        cat.appendChild(probe);
        const width = probe.getBoundingClientRect().width / 100;
        probe.remove();
        return width;
      };

      const render = () => {
        const style = getComputedStyle(cat);
        const inner = cat.clientWidth - parseFloat(style.paddingLeft) - parseFloat(style.paddingRight);
        const charWidth = measureCharWidth();
        if (!charWidth || inner <= 0) return;

        const cols = Math.floor(inner / charWidth);
        const body = Math.max(2, cols - 14);
        const sleeping = root.dataset.theme === 'dark';
        const [left, right] = sleeping ? ['-.-', '-.-'] : eyes;

        const gap = sleeping && body > 8
          ? ' '.repeat(body - 4) + 'z Z '
          : ' '.repeat(body);
        const top = ' /\\_/\\ ' + gap + ' /\\_/\\ ';
        const mid = `( ${left} )` + '_'.repeat(body) + `( ${right} )`;
        const bot = ' > ^ < ' + ' '.repeat(body) + ' > ^ < ';
        cat.textContent = top + '\n' + mid + '\n' + bot;
      };

      const blink = () => {
        const roll = Math.random();
        const targets = roll < 0.3 ? [0, 1] : [roll < 0.65 ? 0 : 1];
        targets.forEach((i) => { eyes[i] = '-.-'; });
        render();
        setTimeout(() => {
          eyes = ['o.o', 'o.o'];
          render();
        }, 160);
      };

      const scheduleBlink = () => {
        setTimeout(() => {
          if (!reducedMotion.matches && root.dataset.theme !== 'dark' && !document.hidden) blink();
          scheduleBlink();
        }, 3500 + Math.random() * 4500);
      };

      let resizeRaf = 0;
      window.addEventListener('resize', () => {
        cancelAnimationFrame(resizeRaf);
        resizeRaf = requestAnimationFrame(render);
      });
      new MutationObserver(render).observe(root, { attributes: true, attributeFilter: ['data-theme'] });

      render();
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(render);
      scheduleBlink();
    })();
  </script>
  <script is:inline>
    (() => {
      // Sidebar tag hover dims post rows in other categories.
      const tags = document.querySelectorAll('.home-tag[data-cat]');
      if (!tags.length) return;

      const clear = () => {
        document.querySelectorAll('.post-row.is-dim').forEach((row) => row.classList.remove('is-dim'));
      };

      tags.forEach((tag) => {
        tag.addEventListener('mouseenter', () => {
          document.querySelectorAll('.post-row[data-cat]').forEach((row) => {
            row.classList.toggle('is-dim', row.dataset.cat !== tag.dataset.cat);
          });
        });
        tag.addEventListener('mouseleave', clear);
      });
    })();
  </script>
  <script is:inline>
    (() => {
      const root = document.documentElement;
      const button = document.querySelector('[data-theme-toggle]');
      if (!(button instanceof HTMLButtonElement)) return;

      const setTheme = (theme) => {
        root.dataset.theme = theme;
        const label = theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode';
        button.setAttribute('aria-label', label);
        button.setAttribute('aria-checked', String(theme === 'dark'));
      };

      // Sync ARIA state with theme set by the head script
      const initial = root.dataset.theme === 'dark' ? 'dark' : 'light';
      button.setAttribute('aria-label', initial === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
      button.setAttribute('aria-checked', String(initial === 'dark'));

      button.addEventListener('click', () => {
        root.classList.add('theme-changing');
        const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
        setTheme(nextTheme);
        localStorage.setItem('theme', nextTheme);
        window.setTimeout(() => root.classList.remove('theme-changing'), 760);
      });
    })();
  </script>
</body>
</html>
