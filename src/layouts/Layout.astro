---
const isHome = Astro.url.pathname === '/';
const {
  title = 'ml, bio, coding | anuraag',
  description = 'thoughts on neural nets, chips, and cells',
  ogType = 'website',
  publishedTime,
  schemaArticle,
  favoriteSong,
} = Astro.props;

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
const siteUrl = Astro.site ? new URL('/', Astro.site).toString() : canonicalUrl;
const ogImageUrl = Astro.site ? new URL('/favicon.ico', Astro.site).toString() : '/favicon.ico';
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}#person`,
  "name": "Anuraag Warudkar",
  "alternateName": ["anuraag", "anuraagw"],
  "url": siteUrl,
  "sameAs": [
    "https://github.com/boopdotpng",
    "https://twitter.com/boopdotpng"
  ],
  "jobTitle": "Software Engineer"
};
const websiteSchema = isHome ? {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}#website`,
  "name": "anuraag",
  "url": siteUrl,
  "publisher": { "@id": `${siteUrl}#person` }
} : null;
let articleSchema = schemaArticle ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": schemaArticle.title,
  "description": schemaArticle.description,
  "datePublished": schemaArticle.publishedTime,
  "dateModified": schemaArticle.updatedTime ?? schemaArticle.publishedTime,
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
  "author": { "@id": `${siteUrl}#person` },
  "publisher": { "@id": `${siteUrl}#person` }
} : null;
if (articleSchema && schemaArticle?.imageUrl) {
  articleSchema = { ...articleSchema, image: [schemaArticle.imageUrl] };
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta
    name="robots"
    content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
  />

  <title>{title}</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="preload" href="/fonts/GoogleSansCode-Variable.ttf" as="font" type="font/ttf" crossorigin />
  <link rel="preload" href="/fonts/GoogleSansCode-VariableItalic.ttf" as="font" type="font/ttf" crossorigin />
  <link rel="stylesheet" href="/katex.min.css" />
  <link rel="stylesheet" href="/markdown.css" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" type="application/rss+xml" title="anuraag — notes" href="/rss.xml" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:site_name" content="anuraag" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <script is:inline>
    (() => {
      const storedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = storedTheme === 'light' || storedTheme === 'dark'
        ? storedTheme
        : (prefersDark ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    })();
  </script>

<style>
  @font-face {
    font-family: "Google Sans Code";
    font-style: normal;
    font-weight: 300 800;
    font-display: swap;
    src: url("/fonts/GoogleSansCode-Variable.ttf") format("truetype");
  }

  @font-face {
    font-family: "Google Sans Code";
    font-style: italic;
    font-weight: 300 800;
    font-display: swap;
    src: url("/fonts/GoogleSansCode-VariableItalic.ttf") format("truetype");
  }

  :root {
    --bg: #faf9f7;
    --fg: #37352f;
    --fg-strong: #1a1a1a;
    --fg-soft: #666055;
    --fg-muted: #888178;
    --fg-faint: #999188;
    --fg-subtle: #aaa39b;
    --accent: #4a7c96;
    --accent-hover: #3a6580;
    --accent-rgb: 74, 124, 150;
    --border-soft: #e8e6e1;
    --border-muted: #e0ddd8;
    --border-strong: #d0cdc6;
    --surface-soft: #f5f3ef;
    --surface-elev: #f0eeeb;
    --surface-note: #f7f6f3;
    --cat-gpu: #3a8a6e;
    --cat-ml: #c06a20;
    --cat-hardware: #b85a8a;
    --cat-bio: #7c6ab8;
    --cat-misc: #7a8694;
    --shadow-rgb: 0, 0, 0;
    --overlay-bg: rgba(0, 0, 0, 0.72);
    --overlay-control-bg: rgba(0, 0, 0, 0.55);
    --overlay-control-border: rgba(255, 255, 255, 0.18);
    --overlay-text: rgba(255, 255, 255, 0.9);
    --overlay-text-muted: rgba(255, 255, 255, 0.75);
    --font-size: 16px;
    --font-sans: Charter, "Bitstream Charter", "Sitka Text", Cambria, serif;
    --font-mono: "Google Sans Code", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    color-scheme: light;
  }

  :root[data-theme='dark'] {
    --bg: #15161b;
    --fg: #d2ced8;
    --fg-strong: #f3f1fb;
    --fg-soft: #9993a3;
    --fg-muted: #7b7489;
    --fg-faint: #6d667c;
    --fg-subtle: #5f596f;
    --accent: #9f89d6;
    --accent-hover: #b39cea;
    --accent-rgb: 159, 137, 214;
    --border-soft: #33353d;
    --border-muted: #3c3e49;
    --border-strong: #484b57;
    --surface-soft: #1c1d23;
    --surface-elev: #22232a;
    --surface-note: #272832;
    --cat-gpu: #79c8a8;
    --cat-ml: #e9b16f;
    --cat-hardware: #e1a3c5;
    --cat-bio: #b8a6ee;
    --cat-misc: #a4afc1;
    --shadow-rgb: 8, 9, 12;
    --overlay-bg: rgba(10, 12, 17, 0.8);
    --overlay-control-bg: rgba(20, 22, 30, 0.72);
    --overlay-control-border: rgba(220, 216, 232, 0.26);
    --overlay-text: rgba(243, 239, 252, 0.94);
    --overlay-text-muted: rgba(213, 204, 232, 0.8);
    color-scheme: dark;
  }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans);
    line-height: 1.5;
    font-size: var(--font-size);
    transition: background-color 0.42s ease, color 0.42s ease;
  }

  html.theme-changing,
  html.theme-changing * {
    transition-property: color, background-color, border-color, box-shadow, text-shadow, fill, stroke;
    transition-duration: 0.42s;
    transition-timing-function: ease;
  }

  code, pre, kbd, samp {
    font-family: var(--font-mono);
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem clamp(1rem, 4vw, 2rem);
    box-sizing: border-box;
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    font-family: var(--font-mono);
  }

  .home-song {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--fg-faint);
    text-decoration: none;
  }

  .home-song:hover .song-title {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .song-icon {
    color: var(--fg-subtle);
  }

  .song-title {
    color: var(--fg-soft);
    letter-spacing: 0.02em;
    transition: color 0.42s ease;
  }

  .site-title {
    font-size: 0.85rem;
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .site-title a {
    color: var(--fg);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .site-title a:hover {
    text-decoration: none;
  }

  .site-title a:hover .site-label {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .site-title a .arrow {
    font-size: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 1em;
    line-height: 1;
    color: var(--fg-subtle);
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  nav a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.82rem;
    padding: 0.35rem 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  nav a:hover {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .rss-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    color: var(--fg-muted);
  }

  .rss-link:hover {
    color: var(--fg);
  }

  .rss-link svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .rss-link .rss-dot {
    transform-origin: center;
  }

  .theme-toggle {
    border: 1px solid var(--border-muted);
    background: var(--surface-soft);
    color: var(--fg-muted);
    font-size: 0.78rem;
    line-height: 1;
    width: 1.95rem;
    height: 1.95rem;
    border-radius: 999px;
    padding: 0;
    cursor: pointer;
    display: inline-grid;
    place-items: center;
    transition: border-color 0.42s ease, color 0.42s ease, background-color 0.42s ease;
  }

  .theme-toggle:hover {
    color: var(--fg);
    border-color: var(--accent);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid rgba(var(--accent-rgb), 0.35);
    outline-offset: 2px;
  }

  .theme-toggle-icon {
    font-size: 0.92rem;
    transform: translateY(-0.5px);
  }

  @media (max-width: 600px) {
    .home-song {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html,
    body,
    html.theme-changing,
    html.theme-changing *,
    .song-title,
    .theme-toggle {
      transition: none !important;
    }
  }

  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 2rem);
  }

  /* Blog post pages get slightly different treatment */
  main:has(.post-content) {
    padding-bottom: 4rem;
  }

  .post-card {
    display: block;
    padding: 1rem;
    margin-bottom: 1rem;
    border: 1px solid var(--border-muted);
    text-decoration: none;
    color: inherit;
  }

  .post-card:hover {
    background: var(--surface-elev);
  }
</style>

  <script type="application/ld+json">{JSON.stringify(personSchema)}</script>
  {websiteSchema && <script type="application/ld+json">{JSON.stringify(websiteSchema)}</script>}
  {articleSchema && <script type="application/ld+json">{JSON.stringify(articleSchema)}</script>}

</head>
<body>
  <header>
    {isHome && favoriteSong && (
      <a class="home-song" href={favoriteSong.url} target="_blank" aria-label="Favorite song right now">
        <span class="song-icon" aria-hidden="true">o))</span>
        <span class="song-title">{favoriteSong.title}</span>
      </a>
    )}
    {!isHome && (
      <div class="site-title">
        <a href="/">
          <span class="arrow">&#8592;</span>
          <span class="site-label">anuraagw.me</span>
        </a>
      </div>
    )}
    <nav>
      <ul>
        <li>
          <button
            type="button"
            class="theme-toggle"
            data-theme-toggle
            aria-label="Switch to dark mode"
            aria-pressed="false"
            title="Toggle theme"
          >
            <span class="theme-toggle-icon" aria-hidden="true">◐</span>
          </button>
        </li>
        <li>
          <a class="rss-link" href="/rss.xml" aria-label="RSS feed">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M6.2 17.8a1.6 1.6 0 1 1-3.2 0 1.6 1.6 0 0 1 3.2 0Z" class="rss-dot"></path>
              <path d="M4 10.2v2.6c3.9 0 7 3.1 7 7h2.6c0-5.3-4.3-9.6-9.6-9.6Z"></path>
              <path d="M4 4v2.6c7.3 0 13.4 6 13.4 13.4H20C20 10.1 13.9 4 4 4Z"></path>
            </svg>
          </a>
        </li>
        <li><a href="https://twitter.com/boopdotpng" target="_blank">@boopdotpng</a></li>
        <li><a href="https://github.com/boopdotpng" target="_blank">github</a></li>
      </ul>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <script is:inline>
    (() => {
      const root = document.documentElement;
      const button = document.querySelector('[data-theme-toggle]');
      if (!(button instanceof HTMLButtonElement)) return;

      const setTheme = (theme) => {
        root.dataset.theme = theme;
        const label = theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode';
        button.setAttribute('aria-label', label);
        button.setAttribute('aria-pressed', String(theme === 'dark'));
      };

      setTheme(root.dataset.theme === 'dark' ? 'dark' : 'light');

      button.addEventListener('click', () => {
        root.classList.add('theme-changing');
        const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
        setTheme(nextTheme);
        localStorage.setItem('theme', nextTheme);
        window.setTimeout(() => root.classList.remove('theme-changing'), 460);
      });
    })();
  </script>
</body>
</html>
